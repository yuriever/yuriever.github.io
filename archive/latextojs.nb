Cell[CellGroupData[{

Cell["To translate latex macros into js", "Subsection",
 CellChangeTimes->{{3.8612932760308228`*^9, 
  3.861293291390017*^9}},ExpressionUUID->"d568c97f-4031-482a-9b04-\
e455ae44140c"],

Cell["\<\
the following symbols in js should be enclosed by \[OpenCurlyQuote]\
\[CloseCurlyQuote]
. - +\
\>", "Text",
 CellChangeTimes->{{3.8763680151356497`*^9, 
  3.876368066296423*^9}},ExpressionUUID->"4e798141-5946-4f22-9dbd-\
f0836cf973cf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"macro", "//", "Clear"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ruleLaTeXToJS", "//", "Clear"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"macro", "[", "\"\<withpara\>\"", "]"}], "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"macro", "[", "\"\<plain\>\"", "]"}], "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"macro", "[", "\"\<unvalid\>\"", "]"}], "=", 
    RowBox[{"{", "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "\"\<regulating\>\"", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"\"\< \>\"", ".."}], "->", "\"\< \>\""}], ",", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"\"\<%\>\"", "~~", "rest___"}], ":>", 
       RowBox[{"\"\<//\>\"", "~~", "rest"}]}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{"\"\<\\\\renewcommand\>\"", "->", "\"\<\\\\newcommand\>\""}], 
      ",", "\n", "\t", 
      RowBox[{"\"\<\\\\newmathcommand\>\"", "->", "\"\<\\\\newcommand\>\""}], 
      ",", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"\"\<\\\\providecommand\>\"", "~~", "__"}], ":>", "\"\<\>\""}],
       ",", "\n", "\t", 
      RowBox[{
       RowBox[{"\"\<\\\\AtBeginDocument{\>\"", "~~", 
        RowBox[{"Longest", "[", "string__", "]"}], "~~", "\"\<}\>\""}], ":>", 
       "string"}]}], "\n", "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "\"\<withpara\>\"", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}[\>\"", "~~", 
       RowBox[{"num_", "?", "DigitQ"}], "~~", "\"\<]{\>\"", "~~", 
       RowBox[{"Longest", "[", "macroFunction__", "]"}], "~~", "\"\<}\>\""}], 
      ":>", "\n", "\t\t", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "\"\<withpara\>\""}], ",", 
           RowBox[{"\"\<\\\\\>\"", "~~", "macroName", "~~", 
            RowBox[{"StringRepeat", "[", 
             RowBox[{"\"\<{a}\>\"", ",", 
              RowBox[{"ToExpression", "@", "num"}]}], "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\t\t\t", 
         RowBox[{
         "macroName", "~~", "\"\<: ['{\>\"", "~~", "macroFunction", "~~", 
          "\"\<}', \>\"", "~~", "num", "~~", "\"\<]\>\""}]}]}], 
       "\[IndentingNewLine]", "\t\t", "]"}]}], "\[IndentingNewLine]", "}"}]}],
    ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "\"\<plain\>\"", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}{\>\"", "~~", 
       RowBox[{"Longest", "[", "macroFunction__", "]"}], "~~", "\"\<}\>\""}], 
      ":>", "\n", "\t\t", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "\"\<plain\>\""}], ",", 
           RowBox[{"\"\<\\\\\>\"", "~~", "macroName"}]}], "]"}], ";", 
         "\[IndentingNewLine]", "\t\t\t", 
         RowBox[{
         "macroName", "~~", "\"\<: '{\>\"", "~~", "macroFunction", "~~", 
          "\"\<}'\>\""}]}]}], "\[IndentingNewLine]", "\t\t", "]"}]}], 
     "\[IndentingNewLine]", "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "\"\<unvalid\>\"", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand\>\"", "~~", "___", "~~", "\"\<{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}\>\"", "~~",
        "rest__"}], ":>", "\n", "\t\t", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "\"\<unvalid\>\""}], ",", "macroName"}], 
          "]"}], ";", "\[IndentingNewLine]", "\t\t\t", "\"\<\>\""}]}], "\n", 
       "\t\t", "]"}]}], "\[IndentingNewLine]", "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"laTeXToJS", "[", "str_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "var", "}"}], ",", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"var", "[", "1", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"str", "//", 
            RowBox[{
             RowBox[{"StringSplit", "[", 
              RowBox[{"#", ",", "\"\<\\n\>\""}], "]"}], "&"}]}], "//", "\n", 
           "\t\t", 
           RowBox[{
            RowBox[{"Nest", "[", 
             RowBox[{
              RowBox[{"StringReplace", "[", 
               RowBox[{"ruleLaTeXToJS", "@", "\"\<regulating\>\""}], "]"}], 
              ",", "#", ",", "2"}], "]"}], "&"}]}], "//", "\n", "\t\t", 
          RowBox[{"StringReplace", "[", 
           RowBox[{"ruleLaTeXToJS", "@", "\"\<withpara\>\""}], "]"}]}], "//", 
         "\n", "\t\t", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"ruleLaTeXToJS", "@", "\"\<plain\>\""}], "]"}]}], "//", 
        "\n", "\t\t", 
        RowBox[{"StringReplace", "[", 
         RowBox[{"ruleLaTeXToJS", "@", "\"\<unvalid\>\""}], "]"}]}], "//", 
       "\n", "\t\t", 
       RowBox[{"DeleteCases", "[", "\"\<\>\"", "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"macro", "@", "\"\<withpara\>\""}], "//", 
        RowBox[{
         RowBox[{"Riffle", "[", 
          RowBox[{"#", ",", "\"\< \\\\\\\\ \\n \>\"", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", 
             RowBox[{"-", "1"}], ",", "10"}], "}"}]}], "]"}], "&"}]}], "//", 
       "\n", "\t\t", 
       RowBox[{
        RowBox[{"StringRiffle", "[", 
         RowBox[{"#", ",", "\"\<\\\\, \>\""}], "]"}], "&"}]}], "//", 
      "Print"}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"macro", "@", "\"\<plain\>\""}], "//", 
        RowBox[{
         RowBox[{"Riffle", "[", 
          RowBox[{"#", ",", "\"\< \\\\\\\\ \\n\>\"", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", 
             RowBox[{"-", "1"}], ",", "10"}], "}"}]}], "]"}], "&"}]}], "//", 
       "\n", "\t\t", 
       RowBox[{
        RowBox[{"StringRiffle", "[", 
         RowBox[{"#", ",", "\"\<\\\\, \>\""}], "]"}], "&"}]}], "//", 
      "Print"}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"macro", "@", "\"\<unvalid\>\""}], "//", "Print"}], ";", "\n", 
     "\t", 
     RowBox[{
      RowBox[{"macro", "[", "\"\<withpara\>\"", "]"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\n", "\t", 
     RowBox[{
      RowBox[{"macro", "[", "\"\<plain\>\"", "]"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\n", "\t", 
     RowBox[{
      RowBox[{"macro", "[", "\"\<unvalid\>\"", "]"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"var", "[", "2", "]"}], "=", 
      RowBox[{
