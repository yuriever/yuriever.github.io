'{\\\\bar{V}_{-}}',\\nVcausal: '{\\\\bar{V}_{\\\\pm}}',\\n// Special \
functions,\\nrising: ['{#1^{\\\\overline{#2}}\\\\,}', 2],\\n// Rising \
