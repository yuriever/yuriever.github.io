Cell[CellGroupData[{

Cell["To translate latex macros into js", "Subsection",
 CellChangeTimes->{{3.8612932760308228`*^9, 
  3.861293291390017*^9}},ExpressionUUID->"d568c97f-4031-482a-9b04-\
e455ae44140c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"macro", "[", "valid", "]"}], "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"macro", "[", "unvalid", "]"}], "=", 
    RowBox[{"{", "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "regulating", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{"\"\< \>\"", ".."}], "->", "\"\< \>\""}], ",", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"\"\<%\>\"", "~~", "rest___"}], "->", 
       RowBox[{"\"\<//\>\"", "~~", "rest"}]}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{"\"\<\\\\renewcommand\>\"", "->", "\"\<\\\\newcommand\>\""}], 
      ",", "\n", "\t", 
      RowBox[{"\"\<\\\\newmathcommand\>\"", "->", "\"\<\\\\newcommand\>\""}], 
      ",", "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"\"\<\\\\providecommand\>\"", "~~", "__"}], ":>", 
       "\"\<\>\""}]}], "\n", "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "withpara", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}[\>\"", "~~", 
       RowBox[{"num_", "?", "DigitQ"}], "~~", "\"\<]{\>\"", "~~", 
       RowBox[{"Longest", "[", "macroFunction__", "]"}], "~~", "\"\<}\>\""}], 
      "\[IndentingNewLine]", "\t", ":>", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "valid"}], ",", "macroName"}], "]"}], ";", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{
         "macroName", "~~", "\"\<: ['{\>\"", "~~", "macroFunction", "~~", 
          "\"\<}', \>\"", "~~", "num", "~~", "\"\<]\>\""}]}]}], 
       "\[IndentingNewLine]", "\t", "]"}]}], "\[IndentingNewLine]", "}"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "plain", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}{\>\"", "~~", 
       RowBox[{"Longest", "[", "macroFunction__", "]"}], "~~", "\"\<}\>\""}], 
      "\[IndentingNewLine]", "\t", ":>", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "valid"}], ",", "macroName"}], "]"}], ";", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{
         "macroName", "~~", "\"\<: '{\>\"", "~~", "macroFunction", "~~", 
          "\"\<}'\>\""}]}]}], "\[IndentingNewLine]", "\t", "]"}]}], 
     "\[IndentingNewLine]", "}"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ruleLaTeXToJS", "[", "unvalid", "]"}], "=", 
    RowBox[{"{", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"\"\<\\\\newcommand\>\"", "~~", "___", "~~", "\"\<{\\\\\>\"", "~~", 
       RowBox[{"Shortest", "[", "macroName__", "]"}], "~~", "\"\<}\>\"", "~~",
        "rest__"}], "\[IndentingNewLine]", "\t", ":>", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t", 
        RowBox[{
         RowBox[{"AppendTo", "[", 
          RowBox[{
           RowBox[{"macro", "@", "unvalid"}], ",", "macroName"}], "]"}], ";", 
         "\[IndentingNewLine]", "\t\t", "\"\<\>\""}]}], "\n", "\t", "]"}]}], 
     "\[IndentingNewLine]", "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"laTeXToJS", "[", "str_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "var", "}"}], ",", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"var", "[", "1", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"str", "//", 
            RowBox[{
             RowBox[{"StringSplit", "[", 
              RowBox[{"#", ",", "\"\<\\n\>\""}], "]"}], "&"}]}], "\n", "\t\t",
            "//", 
           RowBox[{"StringReplace", "[", 
            RowBox[{"ruleLaTeXToJS", "@", "regulating"}], "]"}]}], 
          "\[IndentingNewLine]", "\t\t", "//", 
          RowBox[{"StringReplace", "[", 
           RowBox[{"ruleLaTeXToJS", "@", "withpara"}], "]"}]}], 
         "\[IndentingNewLine]", "\t\t", "//", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"ruleLaTeXToJS", "@", "plain"}], "]"}]}], 
        "\[IndentingNewLine]", "\t\t", "//", 
        RowBox[{"StringReplace", "[", 
         RowBox[{"ruleLaTeXToJS", "@", "unvalid"}], "]"}]}], 
       "\[IndentingNewLine]", "\t\t", "//", 
       RowBox[{"DeleteCases", "[", "\"\<\>\"", "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{
      RowBox[{"macro", "@", "valid"}], "//", "Print"}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{
      RowBox[{"macro", "@", "unvalid"}], "//", "Print"}], ";", 
     "\[IndentingNewLine]", "\t\t", 
     RowBox[{
      RowBox[{"macro", "@", "valid"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t\t", 
     RowBox[{
      RowBox[{"macro", "@", "unvalid"}], "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"var", "[", "2", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"StringInsert", "[", 
          RowBox[{"#", ",", "\"\<,\\n\>\"", ",", 
           RowBox[{"-", "1"}]}], "]"}], "&"}], "/@", 
        RowBox[{"var", "[", "1", "]"}]}], "//", 
       RowBox[{
        RowBox[{"StringExpression", "@@", "#"}], "&"}]}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Code",
 CellChangeTimes->{{3.8610086906362057`*^9, 3.861008723373094*^9}, {
   3.86100880092346*^9, 3.861008836550788*^9}, {3.861009092784589*^9, 
   3.8610091040637827`*^9}, {3.861009143792862*^9, 3.861009166141204*^9}, {
   3.8610092874584723`*^9, 3.8610094742621717`*^9}, {3.861084679738806*^9, 
   3.861084682262789*^9}, {3.8610848030332823`*^9, 3.861084858519862*^9}, {
   3.861084899726149*^9, 3.861084900810862*^9}, {3.861085105911313*^9, 
   3.8610851067348757`*^9}, {3.861085149757353*^9, 3.861085156948626*^9}, {
   3.861085306866438*^9, 3.861085314624105*^9}, {3.861085562585973*^9, 
   3.861085570137896*^9}, {3.861085605453101*^9, 3.8610856368207407`*^9}, {
   3.8610857095485287`*^9, 3.861085764537982*^9}, {3.861085843154003*^9, 
   3.861085843328067*^9}, {3.8610862435024242`*^9, 3.861086261918003*^9}, {
   3.86108631616949*^9, 3.86108639372663*^9}, {3.861086512808063*^9, 
   3.861086572012146*^9}, {3.86108663868672*^9, 3.861086685203734*^9}, {
   3.861086883738265*^9, 3.861086950346982*^9}, {3.861087089999832*^9, 
   3.861087090241974*^9}, {3.8610872578448067`*^9, 3.861087260201172*^9}, {
   3.8610872950755053`*^9, 3.861087298092703*^9}, {3.861087451412369*^9, 
   3.861087496845285*^9}, {3.861087556942865*^9, 3.86108756238345*^9}, {
   3.861094223374922*^9, 3.861094360723469*^9}, {3.8610965884412823`*^9, 
   3.8610966475606337`*^9}, {3.861096698652952*^9, 3.8610967473456593`*^9}, {
