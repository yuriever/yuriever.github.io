Cell[BoxData["\<\"// size control of tilde, bar and hat,\\nwave: \
['{\\\\widetilde{#1}}', 1],\\nbar: ['{\\\\overline{#1}}', 1],\\nhat: \
['{\\\\widehat{#1}}', 1],\\ngeq: '{\\\\geqslant}',\\nleq: \
'{\\\\leqslant}',\\n// to suppress the numbering in align,\\nnn: \
'{\\\\nonumber}',\\n// colored text,\\nred: ['{\\\\textcolor{red}{#1}}', \
1],\\norange: ['{\\\\textcolor{orange}{#1}}', 1],\\nblue: \
['{\\\\textcolor{blue}{#1}}', 1],\\npurple: ['{\\\\textcolor{purple}{#1}}', \
1],\\npink: ['{\\\\textcolor{pink}{#1}}', 1],\\nnotethat: \
['{\\\\textcolor{red}{#1}}', 1],\\nimpliesthat: '{$\\\\implies$}',\\n// \
shortcuts used in CFT,\\n// vacuum,\\nvac: '{\\\\ket{0}}',\\n// vacuum \
expectation value,\\nvev: ['{\\\\langle #1 \\\\rangle}', 1],\\n// field \
operator,\\nop: '{\\\\cO}',\\n// shadow operator,\\nopshadow: \
'{\\\\wave{\\\\op}}',\\nfshadow: '{\\\\wave{\\\\f}}',\\n// composite \
operator,\\nopcomposite: '{\\\\op_{e}}',\\n// singlet \
structure,\\nsingletstructure: '{r=1}',\\n// Gramian matrix,\\ngram: \
'{G}',\\n// stripped four-point functions,\\nfourpt: '{\\\\cG}',\\n// \
stripped blocks,\\nblockstripped: '{g}',\\n// blocks with kinematical \
factors,\\nblockdressed: '{G}',\\n// stripped partial waves,\\nCPWstripped: \
'{\\\\psi}',\\n// partial waves with kinematical factors,\\nCPWdressed: \
'{\\\\Psi}',\\n// highest weight module,\\nrep: ['{\\\\cV_{#1}}', 1],\\n// \
unitary module,\\nurep: ['{\\\\cE_{#1}}', 1],\\n// celestial \
sphere,\\ncsphere: '{$\\\\mathcal{CS}^2$}',\\n// celestial ring,\\ncring: '{$\
\\\\mathcal{CS}^1$}',\\n// transverse momentum,\\npT: '{p_{\\\\perp}}' ,\\n// \
transverse direction,\\nxT: '{x_{\\\\perp}}' ,\\n// unit fm,\\nfm: \
'{\\\\operatorname{fm}}',\\n// unit Gev,\\nGeV: \
['{\\\\operatorname{GeV}^{#1}}', 1],\\n// in state,\\nain: \
'{a_{\\\\operatorname{in}}}',\\n// out state,\\naout: \
'{a_{\\\\operatorname{out}}}',\\n// vector p,\\nvp: '{\\\\vec{p}}',\\n// \
vector x,\\nvx: '{\\\\vec{x}}',\\n// complex coordinates,\\nhb: \
'{\\\\bar{h}}',\\nwbar: '{\\\\bar{w}}',\\nzbar: '{\\\\bar{z}}',\\nTbar: \
'{\\\\bar{T}}',\\nLbar: '{\\\\bar{L}}',\\npsib: '{\\\\bar{\\\\psi}}',\\n// \
