Cell[BoxData[{
 RowBox[{
  RowBox[{"string", "//", "Clear"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"string", "[", "latex", "]"}], ":=", 
   InterpretationBox[
    DynamicModuleBox[{Typeset`open = False}, 
     TemplateBox[{"String", 
       StyleBox[
       "\"latex macro examples\"", "IconizedCustomName", StripOnInput -> 
        False], 
       GridBox[{{
          RowBox[{
            TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            TagBox["String", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"String length: \"", "IconizedLabel"], 
            "\[InvisibleSpace]", 
            TagBox["7616", "IconizedItem"]}]}, {
          RowBox[{
            TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
            
            TagBox["7680", "IconizedItem"]}]}}, 
        GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
        "Column", 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
       Dynamic[Typeset`open]},
      "IconizedObject"]],
    "\[IndentingNewLine]\n% Size control of tilde, bar and hat\n% \
https://tex.stackexchange.com/questions/365376\n\
\\newcommand{\\wave}[1]{\\widetilde{#1}}\n\
\\renewcommand{\\bar}[1]{\\overline{#1}}\n\
\\renewcommand{\\hat}[1]{\\widehat{#1}}\n\\renewcommand{\\geq}{\\geqslant}\n\
