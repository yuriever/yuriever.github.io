miscellaneous,\\n// discontinuity,\\ndisc: '{\\\\operatorname{Disc}}',\\n// \
phantom equal at the beginning,\\npeq: '{\\\\phantom{=}}',\\n// linear \
span,\\nvspan: ['{\\\\operatorname{span}\\\\set{ #1 }}', 1],\\n// \
sets,\\nset: ['{\\\\left\\\\{ #1 \\\\right\\\\}}', 1],\\n// case,\\ncase: ['{\
\\\\begin{cases} #1 \\\\end{cases}}', 1],\\n// left hand side,\\nlhs: \
'{\\\\text{l.h.s}}',\\n// right hand side,\\nrhs: '{\\\\text{r.h.s}}',\\n// \
