Cell[BoxData[{
 RowBox[{
  RowBox[{"string", "//", "Clear"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"string", "[", "]"}], ":=", 
  InterpretationBox[
   DynamicModuleBox[{Typeset`open = False}, 
    TemplateBox[{"String", "StringIcon", 
      GridBox[{{
         RowBox[{
           TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
           TagBox["String", "IconizedItem"]}]}, {
         RowBox[{
           TagBox["\"String length: \"", "IconizedLabel"], 
           "\[InvisibleSpace]", 
           TagBox["9032", "IconizedItem"]}]}, {
         RowBox[{
           TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
           TagBox["9216", "IconizedItem"]}]}}, 
       GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
       "Column", 
       GridBoxItemSize -> {
        "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
      Dynamic[Typeset`open]},
     "IconizedObject"]],
   "\n% size control of tilde, bar and hat\n\
\\newcommand{\\wave}[1]{\\widetilde{#1}}\n\
\\AtBeginDocument{\\renewcommand{\\bar}[1]{\\overline{#1}}}\n\
\\AtBeginDocument{\\renewcommand{\\hat}[1]{\\widehat{#1}}}\n\
\\renewcommand{\\geq}{\\geqslant}\n\\renewcommand{\\leq}{\\leqslant}\n\n% to \
suppress the numbering in align\n\\newcommand{\\nn}{\\nonumber}\n\n% colored \
text\n\\newcommand{\\red}[1]{\\textcolor{red}{#1}}\n\
\\newcommand{\\orange}[1]{\\textcolor{orange}{#1}}\n\
\\newcommand{\\blue}[1]{\\textcolor{blue}{#1}}\n\
\\newcommand{\\purple}[1]{\\textcolor{purple}{#1}}\n\
\\newcommand{\\pink}[1]{\\textcolor{pink}{#1}}\n\
\\newcommand{\\notethat}[1]{\\textcolor{red}{#1}}\n\
\\newcommand{\\impliesthat}{$\\implies$}\n\n% shortcuts used in CFT\n% vacuum\
\n\\newcommand{\\vac}{\\ket{0}}\n% vacuum expectation value\n\
\\renewcommand{\\vev}[1]{\\langle #1 \\rangle}\n% field operator\n\
\\providecommand{\\op}{\\cO}\n\\renewcommand{\\op}{\\cO}\n% shadow operator\n\
\\newcommand{\\opshadow}{\\wave{\\op}}\n\\newcommand{\\fshadow}{\\wave{\\f}}\n\
% composite operator\n\\newcommand{\\opcomposite}{\\op_{e}}\n% singlet \
structure\n\\newcommand{\\singletstructure}{r=1}\n% Gramian matrix\n\
\\newcommand{\\gram}{G}\n% stripped four-point functions\n\
\\newcommand{\\fourpt}{\\cG}\n% stripped blocks\n\
\\newcommand{\\blockstripped}{g}\n% blocks with kinematical factors\n\
\\newcommand{\\blockdressed}{G}\n% stripped partial waves\n\
\\newcommand{\\CPWstripped}{\\psi}\n% partial waves with kinematical factors\n\
\\newcommand{\\CPWdressed}{\\Psi}\n% highest weight module\n\
\\newcommand{\\rep}[1]{\\cV_{#1}}\n% unitary module\n\\newcommand{\\urep}[1]{\
\\cE_{#1}}\n% celestial sphere\n\\newcommand{\\csphere}{$\\mathcal{CS}^2$}\n% \
celestial ring\n\\newcommand{\\cring}{$\\mathcal{CS}^1$}\n% transverse \
momentum\n\\newcommand{\\pT}{p_{\\perp}} \n% transverse direction\n\
\\newcommand{\\xT}{x_{\\perp}} \n% unit fm\n\
\\newcommand{\\fm}{\\operatorname{fm}}\n% unit Gev\n\
\\newcommand{\\GeV}[1]{\\operatorname{GeV}^{#1}}\n% in state\n\
\\newcommand{\\ain}{a_{\\operatorname{in}}}\n% out state\n\
\\newcommand{\\aout}{a_{\\operatorname{out}}}\n\n% vector p\n\
\\newmathcommand{\\vp}{\\vec{p}}\n% vector x\n\
\\newmathcommand{\\vx}{\\vec{x}}\n% complex coordinates\n\
\\newcommand{\\hb}{\\bar{h}}\n\\newcommand{\\wbar}{\\bar{w}}\n\
\\newcommand{\\zbar}{\\bar{z}}\n\\newcommand{\\Tbar}{\\bar{T}}\n\\newcommand{\
\\Lbar}{\\bar{L}}\n\\newcommand{\\psib}{\\bar{\\psi}}\n% Dirac conjugate\n\
\\newcommand{\\Vfuture}{\\bar{V}_{+}}\n\\newcommand{\\Vpast}{\\bar{V}_{-}}\n\
\\newcommand{\\Vcausal}{\\bar{V}_{\\pm}}\n% Special functions\n\
\\newcommand{\\rising}[2]{#1^{\\overline{#2}}\\,}\n% Rising factorials \n\
\\newcommand{\\falling}[2]{#1^{\\underline{#2}}\\,}\n% Falling factorials\n% \
Hypergeometric functions\n\\newcommand{\\Faa}{{}_{1}F_{1}}\n\
\\newcommand{\\Fab}{{}_{1}F_{2}}\n\\newcommand{\\Fba}{{}_{2}F_{1}}\n\
\\newcommand{\\Fcb}{{}_{3}F_{2}}\n\n\n% miscellaneous\n% discontinuity\n\
\\newcommand{\\disc}{\\operatorname{Disc}}\n% phantom equal at the beginning\n\
\\newcommand{\\peq}{\\phantom{=}}\n% linear span\n\
\\newcommand{\\vspan}[1]{\\operatorname{span}\\set{ #1 }}\n% sets\n\
\\newcommand{\\set}[1]{\\left\\{ #1 \\right\\}}\n% case\n\
\\newcommand{\\case}[1]{\\begin{cases} #1 \\end{cases}}\n% left hand side\n\
\\newcommand{\\lhs}{\\text{l.h.s}}\n% right hand side\n\
\\newcommand{\\rhs}{\\text{r.h.s}}\n% to control spacings in integral\n\
\\newcommand{\\intt}[1]{\\int #1\\,}\n% to control spacings in integral\n\
\\newcommand{\\inttt}[2]{\\int_{#2} #1\\,}\n% half\n\
\\newcommand{\\half}{\\frac{1}{2}}\n% dot\n\\newmathcommand{\\.}{\\cdot}\n% \
times\n\\newcommand{\\x}{\\times}\n% tensor product\n\
\\newcommand{\\ox}{\\otimes}\n% direct sum\n\\newcommand{\\os}{\\oplus}\n% \
wedge product\n\\newcommand{\\w}{\\wedge}\n% infinity\n\\renewcommand{\\inf}{\
