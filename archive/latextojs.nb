\\operatorname{vol}} \n% induction\n\\newcommand{\\Ind}{\\operatorname{Ind}} \
\n% radical of algebra\n\\newcommand{\\rad}{\\operatorname{rad}} \n% dual \
space\n\\newcommand{\\dual}[1]{{#1}^\\vee}\n% inverse\n\
\\renewcommand{\\-}{{-1}} \n% Hermitian conjugate\n\
\\newcommand{\\+}{\\dagger}\n% Hilbert space\n\
\\newmathcommand{\\H}{\\mathcal{H}}\n% Moduli spaces\n\
\\newcommand{\\M}{\\mathcal{M}}\n\n\n% categories\n\
\\newcommand{\\setcat}{\\operatorname{Set}}\n\
\\newcommand{\\veccat}{\\operatorname{Vec}}\n\
\\newcommand{\\catcat}{\\operatorname{Cat}}\n% vector spaces\n\
\\newcommand{\\Uvec}{\\mathbb{U}}\n\\newcommand{\\Vvec}{\\mathbb{V}}\n\
\\newcommand{\\Wvec}{\\mathbb{W}}\n\n\n% Greek letters\n\
\\renewcommand{\\a}{\\alpha}\n\\newmathcommand{\\b}{\\beta}\n\
\\newmathcommand{\\c}{\\chi}\n\\newmathcommand{\\d}{\\delta}\n\
\\newcommand{\\D}{\\Delta}\n\\newcommand{\\e}{\\epsilon}\n\\newcommand{\\ve}{\
\\varepsilon}\n\\newcommand{\\g}{\\gamma}\n\\providecommand{\\G}{\\Gamma}\n\
\\renewcommand{\\G}{\\Gamma}\n\\newmathcommand{\\k}{\\kappa}\n\
