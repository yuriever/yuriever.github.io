\\newcommand{\\Vfuture}{\\bar{V}_{+}}\n\\newcommand{\\Vpast}{\\bar{V}_{-}}\n\
\\newcommand{\\Vcausal}{\\bar{V}_{\\pm}}\n% Special functions\n\
\\newcommand{\\rising}[2]{#1^{\\overline{#2}}\\,}\n% Rising factorials \n\
\\newcommand{\\falling}[2]{#1^{\\underline{#2}}\\,}\n% Falling factorials\n% \
Hypergeometric functions\n\
\\newcommand*{\\Fpq}[5]{{}_{#1}F_{#2}\\left(\\genfrac..{0pt}{}{#3}{#4};#5\\\
right)}\n\\newcommand{\\Faa}{{}_{1}F_{1}}\n\\newcommand{\\Fba}{{}_{2}F_{1}}\n\
\\newcommand{\\Fcb}{{}_{3}F_{2}}\n\n\n% Miscellaneous\n% linear span\n\
