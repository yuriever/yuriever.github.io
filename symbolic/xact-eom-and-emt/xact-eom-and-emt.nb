Cell[BoxData[
 RowBox[{
  RowBox[{"ansatz", "[", "\"\<EMT\>\"", "]"}], "=", "\n", "\t", 
  RowBox[{
   RowBox[{"MakeContractionAnsatz", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"a", ",", "b"}], "]"}], 
      RowBox[{"F", "[", 
       RowBox[{"c", ",", "d"}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}], ",", 
