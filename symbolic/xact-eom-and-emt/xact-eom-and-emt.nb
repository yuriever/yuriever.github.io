   3.8759618455763187`*^9, {3.881646012516108*^9, 3.881646015057788*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"50f9c280-9ea2-45af-8c03-2a6771b08814"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"EOM", "[", "fourPartialST", "]"}], "//", "Expand"}], "//", 
  RowBox[{"ReplaceRepeated", "[", "ruleKinScalar", "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"EMT", "[", "fourPartialST", "]"}], "//", "Expand"}], "//", 
  RowBox[{"ReplaceRepeated", "[", "ruleKinScalar", "]"}]}]}], "Code",
