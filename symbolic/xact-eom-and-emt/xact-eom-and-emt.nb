Cell[TextData[{
 "Built on ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"452f4f31-2d54-4117-b98f-b203b77cc2b8"],
 ", ",
 Cell[BoxData[
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{"LHS_", ",", "RHS_", ",", "conditions___"}], "}"}], "]"}]],
  ExpressionUUID->"de03bfa3-99cc-4796-8db4-6554c9579a37"],
 " provides more functionalities like checking index balance and taking \
account of tensor symmetry and metric contraction, which can be turned by \
options."
}], "Text",
