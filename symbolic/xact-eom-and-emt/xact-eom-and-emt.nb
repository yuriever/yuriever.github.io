Cell[CellGroupData[{
Cell["Packages and pre-defined functions", "Subsection",
 CellChangeTimes->{{3.868133354394601*^9, 3.8681333713238792`*^9}, 
   3.874337548617125*^9},ExpressionUUID->"c570a0e4-d6b6-4618-bd79-\
701f481359da"],

Cell["The packages and pre-defined functions are listed below.", "Text",
 CellChangeTimes->{
  3.8746629061312017`*^9},ExpressionUUID->"7c820f07-8f89-4c2d-ba2a-\
771f7ea6e4ca"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}], " ", "=", " ", 
    RowBox[{"{", "\n", "    ", 
     RowBox[{
     "\"\<xAct`xPerm`\>\"", ",", "\n", "    ", "\"\<xAct`xTensor`\>\"", ",", 
      "\n", "    ", "\"\<xAct`xPert`\>\"", ",", "\n", "    ", 
      "\"\<xAct`Invar`\>\"", ",", "\n", "    ", "\"\<xAct`xCoba`\>\"", ",", 
      "\n", "    ", "\"\<xAct`SymManipulator`\>\"", ",", "\n", "    ", 
      "\"\<xAct`xTras`\>\"", ",", "\n", "    ", "\"\<xAct`TexAct`\>\""}], 
     "\n", "}"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "version", " ", "messages", " ", "using", " ", 
    "Block"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Block", "[", " ", 
    RowBox[{
     RowBox[{"{", "Print", "}"}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"Needs", "/@", 
       RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}]}], ";"}]}], "\n", 
    "]"}], ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "dollar", " ", "symbols", " ", "of", " ", "local",
     " ", "variables"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "System`$PrePrint", " ", "=", " ", "xAct`xTensor`ScreenDollarIndices"}], 
   ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "definition", " ", "messages", " ", "of", " ", 
    "objects"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xAct`xTensor`$DefInfoQ", " ", "=", " ", "False"}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "print", " ", "the", " ", "covariant", " ", "derivatives", " ", "as", " ", 
    "prefix"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"xAct`xTensor`$CovDFormat", " ", "=", " ", "\"\<Prefix\>\""}], 
  ";"}]}], "Code",
 CellChangeTimes->{{3.868133279992435*^9, 3.868133279996047*^9}, {
   3.86813332063454*^9, 3.868133321271337*^9}, {3.868133486272317*^9, 
   3.8681335677391443`*^9}, {3.8681422263813*^9, 3.8681422270350027`*^9}, {
   3.868149970353297*^9, 3.868149972432393*^9}, 3.868417294274118*^9, {
   3.868417416890373*^9, 3.868417423649791*^9}, {3.874278067602147*^9, 
   3.874278072214467*^9}, {3.874285221670969*^9, 3.874285278509529*^9}, {
   3.874285510464655*^9, 3.8742855195807323`*^9}, {3.874295905766618*^9, 
   3.874295909011573*^9}, 3.874313594262267*^9, 3.8743136481779747`*^9, {
   3.8743136965856533`*^9, 3.874313698041995*^9}, {3.874337006013891*^9, 
   3.874337006795833*^9}, 3.874633119545739*^9, {3.874633196352462*^9, 
   3.874633199374867*^9}, {3.874633337011435*^9, 3.874633341142356*^9}, 
   3.874634728117763*^9, {3.8750283960142727`*^9, 3.87502839887405*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"b9cdd643-0cbe-4039-9968-fc003bf3fd01"],

Cell[TextData[{
 "For ",
 Cell[BoxData["xAct`"],ExpressionUUID->"b1257005-72f2-47b8-90f8-bdced5484d66"],
 " packages ",
 Cell[BoxData["Needs"],ExpressionUUID->"4d64961e-4325-446b-b511-d2925f8c9c9d"],
 " is better than ",
 Cell[BoxData["Get"],ExpressionUUID->"add93fc4-874f-45ca-99c7-b1d9e60c79b8"],
 ". Besides there are conflict symbols in ",
 Cell[BoxData["xAct`"],ExpressionUUID->"aac9ba83-8d3e-4513-8d54-56acfba96e6c"],
 " and ",
 Cell[BoxData[
  RowBox[{"System`", "/", "GeneralUtilities`"}]],ExpressionUUID->
  "89144ee2-fc3b-4679-88e8-f88bb10c52d8"],
 ".\nThe context specification like ",
 Cell[BoxData[
 "xAct`xTensor`"],ExpressionUUID->"0f861d3b-8347-4aab-b940-6590106c4450"],
 " is not necessary when working in notebook."
}], "Text",
 CellChangeTimes->{{3.874664091755135*^9, 3.8746641085437527`*^9}, {
  3.8747246521430798`*^9, 
  3.874724671443118*^9}},ExpressionUUID->"b3749d1d-d8d6-4fa8-a07c-\
dbf6a79cd6da"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"measure", "::", "usage"}], " ", "=", " ", "\"\<Sqrt[-g]\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"tensorSim", "::", "usage"}], " ", "=", " ", 
    "\"\<x//ContractMetric//Simplification, Simplification = ToCanonical + \
Simplify\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"measure", "[", 
     RowBox[{"metric_", "?", "xAct`xTensor`MetricQ"}], "]"}], " ", ":=", "\n",
     "    ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"xAct`xTensor`SignDetOfMetric", "@", "metric"}], " ", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"\"\<Det\>\"", "<>", 
        RowBox[{"ToString", "@", "metric"}], "<>", "\"\<[]\>\""}], "]"}]}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tensorSim", "[", "expr_", "]"}], " ", ":=", "\n", "    ", 
   RowBox[{
    RowBox[{"expr", "//", "xAct`xTensor`ContractMetric"}], "//", 
    "xAct`xTensor`Simplification"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.868133279992435*^9, 3.868133279996047*^9}, {
   3.86813332063454*^9, 3.868133321271337*^9}, {3.868133486272317*^9, 
   3.8681335677391443`*^9}, {3.8681422263813*^9, 3.8681422270350027`*^9}, {
   3.868149970353297*^9, 3.868149972432393*^9}, 3.868417294274118*^9, {
   3.868417416890373*^9, 3.868417423649791*^9}, {3.874278067602147*^9, 
   3.874278072214467*^9}, {3.874285221670969*^9, 3.874285278509529*^9}, {
   3.874285510464655*^9, 3.874285518117844*^9}, {3.87429587919771*^9, 
   3.8742958978065357`*^9}, 3.8743136166292152`*^9, {3.874660776744227*^9, 
   3.8746607824153547`*^9}, {3.876151175277067*^9, 3.876151176592161*^9}, {
   3.8761530700808067`*^9, 
   3.8761530708931503`*^9}},ExpressionUUID->"71970fbf-eecf-464f-9678-\
33d14a400cac"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{"measure", "[", "metric_", "]"}]],ExpressionUUID->
  "3f7a233b-6ed4-42b7-9760-4ebe836f0cbc"],
 " is to give the square root of metric determinant, and ",
 Cell[BoxData[
  RowBox[{"tensorSim", "[", "expr_", "]"}]],ExpressionUUID->
  "43c0edcb-1d61-47e8-94aa-e82b5a1cef27"],
 " is useful for simplifying expressions, in which Simplification = \
ToCanonical + Simplify."
}], "Text",
 CellChangeTimes->{{3.874664114933648*^9, 3.874664121526023*^9}, {
   3.875013086405602*^9, 3.8750130889831057`*^9}, {3.875021531330266*^9, 
   3.875021548149619*^9}, 3.875933945490753*^9, {3.876004470287112*^9, 
