   3.875926747507456*^9}, {3.875927170811349*^9, 3.875927171385436*^9}},
 CellLabel->"In[50]:=",ExpressionUUID->"22635447-7576-4bc2-bd61-c4e018ca1538"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    StyleBox["c",
     ShowAutoStyles->False,
     AutoSpacing->False],
    $CellContext`cs,
    Editable->False], "\[Rule]", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"2", "-", 
      InterpretationBox[
       StyleBox["d",
        ShowAutoStyles->False,
        AutoSpacing->False],
       xAct`Invar`dim,
       Editable->False]}], 
     RowBox[{"4", " ", 
