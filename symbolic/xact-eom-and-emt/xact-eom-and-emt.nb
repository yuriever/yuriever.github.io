 RowBox[{
  RowBox[{"Off", "[", 
   RowBox[{"Solve", "::", "svars"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ansatzSolution", "[", "\"\<EOM\>\"", "]"}], "=", 
  RowBox[{"First", "@", 
   RowBox[{"SolveConstants", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ansatz", "[", "\"\<EOM\>\"", "]"}], "/.", "ruleFToA"}], ")"}],
      "==", 
     RowBox[{"EOM", "[", "abelianGauge", "]"}]}], "]"}]}]}]}], "Code",
 CellChangeTimes->{{3.875411536066312*^9, 3.875411545681777*^9}, {
