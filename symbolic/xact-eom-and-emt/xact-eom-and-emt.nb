 Cell[BoxData[
  RowBox[{"measure", "@", "metric"}]],ExpressionUUID->
  "b45f12cc-4e70-4333-91d3-8f81d09acd0c"],
 " returns ",
 Cell[BoxData[
  RowBox[{"Sqrt", "[", 
   RowBox[{"-", 
    RowBox[{"Detmetric", "[", "]"}]}], "]"}]],ExpressionUUID->
  "d1a4c1a3-40a5-4ce0-b1b0-2513314383bf"],
 "."
}], "Text",
