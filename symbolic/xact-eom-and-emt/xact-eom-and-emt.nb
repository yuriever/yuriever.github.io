Cell[TextData[{
 "The function ",
 Cell[BoxData[
 "SolveConstants"],ExpressionUUID->"caa27345-c1a8-420a-b56f-a6d3b8864c7d"],
 " built on ",
 Cell[BoxData[
 "System`Solve"],ExpressionUUID->"999f85dc-4bb6-4030-b08a-297e0bc07959"],
 " can solve coefficients in tensorial equations. \n\n",
 Cell[BoxData[
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"{", "eqs__", "}"}], ",", 
    RowBox[{"{", "vars__", "}"}], ",", 
    RowBox[{"{", "elims__", "}"}]}], "]"}]],ExpressionUUID->
  "3f37b030-4ee9-4c11-a052-f3ac15c8a060"],
 " is an undocumented syntax, see the discussion  \
https://mathematica.stackexchange.com/a/41263/86893."
}], "Text",
 CellChangeTimes->{{3.87492151865944*^9, 3.874921544818512*^9}, {
  3.874922588476388*^9, 3.874922674380125*^9}, {3.874922818393718*^9, 
  3.874922927975683*^9}, {3.874922959628026*^9, 3.8749230590973177`*^9}, {
  3.87499696769379*^9, 3.874996985408079*^9}, {3.8759093140171003`*^9, 
  3.8759093171688337`*^9}, {3.875909358084174*^9, 
  3.875909362560779*^9}},ExpressionUUID->"59796a93-0087-4843-a6a7-\
1c7373109f7e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Making ansatz", "Subsection",
 CellChangeTimes->{{3.872733271876554*^9, 
  3.87273327596281*^9}},ExpressionUUID->"ee8602d6-01c6-4b07-8e9f-\
49eb35b9c7e4"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
 "LHS_"],ExpressionUUID->"0f53eb5b-6bfd-4279-a6c5-ca92564a98d5"],
 " in  ",
 Cell[BoxData[
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{"LHS_", ",", "RHS_", ",", "conditions___"}], "}"}], "]"}]],
  ExpressionUUID->"a50a1e37-fd8a-42f7-869f-a60bf9c2dc9c"],
 " cannot contain more than one term, and in some cases it\[CloseCurlyQuote]s \
hard to use for simplifying expressions.\nInstead, there is another method: \
making ansatz and then comparing coefficients - ",
 Cell[BoxData[
 "MakeContractionAnsatz"],ExpressionUUID->
  "ff766ee7-9735-4f22-ad86-154add270f07"],
 " + ",
 Cell[BoxData[
 "SolveConstants"],ExpressionUUID->"30e173c7-cb35-4c6e-8987-72584b661d60"],
 "."
}], "Text",
 CellChangeTimes->{{3.875410903969084*^9, 3.87541110990904*^9}, {
   3.8754111454248533`*^9, 3.8754113505487413`*^9}, 3.875411396275001*^9, {
   3.875411478650573*^9, 3.875411478650647*^9}, {3.875909388005856*^9, 
   3.8759094477400217`*^9}},ExpressionUUID->"196be384-0e9e-4bfb-a385-\
6c45dcd8c5e1"],

Cell[CellGroupData[{

Cell["Ansatz of equation of motion", "Subsubsection",
 CellChangeTimes->{{3.8754113975948887`*^9, 
  3.875411399000444*^9}},ExpressionUUID->"029e06f0-856c-449e-bd60-\
04208ce598fc"],

Cell[TextData[{
 "For example, the equation of motion of abelian gauge theory can be \
re-written in terms of ",
 Cell[BoxData["F"],ExpressionUUID->"1d0e19b4-8cc1-4cce-b5d9-4d826d833df7"],
 ":"
}], "Text",
 CellChangeTimes->{{3.875410903969084*^9, 3.87541110990904*^9}, {
   3.8754111454248533`*^9, 3.8754113505487413`*^9}, 3.875411490934257*^9, {
   3.8759786360523243`*^9, 
   3.875978636793952*^9}},ExpressionUUID->"2ec4b9f9-3502-45c3-9597-\
8bc1788838d0"],

Cell[TextData[{
 "1) construct all terms like ",
 Cell[BoxData[
  RowBox[{"D", " ", "F"}]],ExpressionUUID->
  "c12c07bb-9186-4867-a4d8-1fe6c17dfdb9"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"D", "^", "2"}], " ", "A"}]],ExpressionUUID->
  "f00b09e6-3736-4f52-825d-8a52b73420dc"],
 ", "
}], "Text",
 CellChangeTimes->{{3.875411418899205*^9, 3.8754114638372917`*^9}, {
  3.875961765646585*^9, 
  3.8759617674023857`*^9}},ExpressionUUID->"4668d778-643a-41e7-80c0-\
b054798a298d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ansatz", "[", "\"\<EOM\>\"", "]"}], "=", "\n", "\t", 
  RowBox[{
   RowBox[{"MakeContractionAnsatz", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CD", "[", "a", "]"}], "@", 
      RowBox[{"F", "[", 
       RowBox[{"b", ",", "c"}], "]"}]}], ",", 
     RowBox[{"{", "a", "}"}], ",", 
     RowBox[{"ConstantPrefix", "->", "\"\<a\>\""}]}], "]"}], "+", "\n", "\t", 
   
   RowBox[{"MakeContractionAnsatz", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"CD", "[", "a", "]"}], "@", 
      RowBox[{
       RowBox[{"CD", "[", "b", "]"}], "@", 
       RowBox[{"A", "[", "c", "]"}]}]}], ",", 
     RowBox[{"{", "a", "}"}], ",", 
     RowBox[{"ConstantPrefix", "->", "\"\<b\>\""}]}], "]"}]}]}]], "Code",
 CellChangeTimes->{{3.872734187878317*^9, 3.872734219141149*^9}, {
  3.874289565331765*^9, 3.8742896023740997`*^9}, {3.874336386599115*^9, 
  3.8743363886876583`*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"afb069d1-babf-4a85-90e6-189d12c994eb"],

