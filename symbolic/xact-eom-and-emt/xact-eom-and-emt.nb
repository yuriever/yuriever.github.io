82f018b1768d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"phi", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Phi]\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], ",", "M"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "M", ",", 
    RowBox[{"Antisymmetric", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"cs", ",", 
    RowBox[{"PrintAs", "->", "\"\<c\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefScalarFunction", "[", 
   RowBox[{"alpha", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Alpha]\>\""}]}], "]"}], ";"}]}], "Code",
 CellChangeTimes->{{3.8605836567214136`*^9, 3.860583663333129*^9}, {
   3.860583786180087*^9, 3.8605837869832177`*^9}, {3.860583819074193*^9, 
   3.86058381924725*^9}, {3.8606126849646597`*^9, 3.860612758186241*^9}, {
   3.8606129002557545`*^9, 3.8606129093232894`*^9}, {3.8606134418759995`*^9, 
   3.860613442044799*^9}, {3.860613479662074*^9, 3.8606135095757723`*^9}, {
