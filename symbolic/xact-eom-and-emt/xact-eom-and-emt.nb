Cell[TextData[{
 "We need a method to impose the relation between gauge potential and field \
strength:\n\n\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"a", ",", "b"}], "]"}], "->", 
   RowBox[{
    RowBox[{
     RowBox[{"CD", "[", "a", "]"}], "@", 
     RowBox[{"A", "[", "b", "]"}]}], "-", 
    RowBox[{
     RowBox[{"CD", "[", "b", "]"}], "@", 
     RowBox[{"A", "[", "a", "]"}]}]}]}]],ExpressionUUID->
  "4803691d-4573-4a8d-9287-c6d60aacc223"]
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
  3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
  3.874722729770549*^9}, {3.874724859840152*^9, 3.874724865651198*^9}, {
  3.875012948497933*^9, 3.875012949217291*^9}, {3.875012995588451*^9, 
  3.875012996410304*^9}, {3.875014629537278*^9, 3.8750146563444567`*^9}, {
  3.875028455754752*^9, 3.875028466439206*^9}, {3.8750678641882143`*^9, 
  3.875067876716927*^9}, {3.875995839266363*^9, 
  3.8759958462563457`*^9}},ExpressionUUID->"382e7d32-e114-4d65-8f00-\
2fb548b471d4"],

Cell[TextData[{
 "In Mathematica there are roughly two methods of converting expressions: ",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d688371f-c956-4363-8856-ec08cca76397"],
 " vs. ",
 Cell[BoxData["Set"],ExpressionUUID->"dbc6129c-3380-4f73-b7c9-8a2c97841d05"],
 ", see e.g. the documentation on the standard evaluation sequence: ",
 Cell[BoxData[
  RowBox[{"tutorial", "/", "Evaluation"}]],ExpressionUUID->
  "2464932b-9998-4d6b-bdad-468e4ec445b7"],
 ". \n",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d746d8da-d962-4581-83ad-66350b978205"],
 " is more finer than ",
 Cell[BoxData["Set"],ExpressionUUID->"98019db5-b750-44fa-b9e9-e1f3b484d2e3"],
 " for controlling the evaluation: the user can determine whether to apply \
rules or not, while relations by ",
 Cell[BoxData["Set"],ExpressionUUID->"b44ea15f-3479-4037-b3a0-df0566e98886"],
 " will always be applied automatically."
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
   3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
   3.874722729770549*^9}, {3.874724859840152*^9, 3.874724865651198*^9}, 
   3.875012948497933*^9, {3.8750129851573563`*^9, 3.87501298623281*^9}, {
   3.875013016621004*^9, 3.875013052631103*^9}, {3.875013125441889*^9, 
   3.875013138389717*^9}, {3.87501342579502*^9, 3.8750134680703697`*^9}, {
   3.875013915051552*^9, 3.875013942283339*^9}, {3.875014041092051*^9, 
   3.875014105487253*^9}, {3.8750141455627537`*^9, 3.875014172739987*^9}, {
   3.875014274965941*^9, 3.875014294743494*^9}, {3.875014385062654*^9, 
   3.875014390177971*^9}, {3.875014420459053*^9, 3.875014518168043*^9}, 
   3.875014550814077*^9, {3.875014693070177*^9, 3.875014708653754*^9}, {
   3.875014812555884*^9, 3.875014838119796*^9}, {3.875014887460134*^9, 
   3.8750149093746*^9}, {3.87501495612033*^9, 3.8750150240701513`*^9}, 
   3.875015101209065*^9, {3.875021054566197*^9, 3.875021055557321*^9}, {
   3.8759087752563467`*^9, 3.8759087963250093`*^9}, 
   3.8759961335459957`*^9},ExpressionUUID->"6e9b587f-2a5b-4f9c-8084-\
67064da370ea"],

Cell[TextData[{
 Cell[BoxData["xAct`"],ExpressionUUID->"c3f7ae34-7b74-47c6-8e5d-3e1b09d231f3"],
 " provides analogous functions ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"50c6e84e-bdea-4210-a6c8-ed5a60e5b452"],
 " vs. ",
 Cell[BoxData[
 "IndexSet"],ExpressionUUID->"0c410c8d-569d-4ce3-a11d-97f3a32fec94"],
 ", and their delayed versions ",
 Cell[BoxData[
 "IndexRuleDelayed"],ExpressionUUID->"3b4755d0-d008-4675-b9cd-4f2e5ac4e4ca"],
 " vs. ",
 Cell[BoxData[
 "IndexSetDelayed"],ExpressionUUID->"756d33c4-4e2a-4ba0-8da8-29165e2a029f"],
 ". \nWhen pattern matching, the ",
 Cell[BoxData[
 "\"\<*IndexQ\>\""],ExpressionUUID->"5de84aac-bf8c-48e2-8b32-54ec83f67dc7"],
 "-family can help to specify index types."
}], "Text",
