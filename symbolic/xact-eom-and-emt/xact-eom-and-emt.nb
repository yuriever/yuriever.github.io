Cell[CellGroupData[{

Cell["Connections and derivatives", "Subsubsection",
 CellChangeTimes->{{3.87599803983468*^9, 
  3.87599806209165*^9}},ExpressionUUID->"b09e398b-2dd0-4e26-a5f4-\
122e45322367"],

Cell[TextData[{
 "The function ",
 Cell[BoxData["DefCovD"],
  FormatType->StandardForm,ExpressionUUID->
  "abc972a6-d63e-4767-9d74-ea4ae6cbddce"],
 " is to define connections with torsion or not associated to the metric, \
which can be specified by the options ",
 Cell[BoxData["Torsion"],
  FormatType->StandardForm,ExpressionUUID->
  "c46c380b-b7cf-43c3-a028-10f3ef45303c"],
 " and ",
 Cell[BoxData["FromMetric"],
  FormatType->StandardForm,ExpressionUUID->
  "b7fa3b18-a483-4a9e-846a-11c0396f6f67"],
 " respectively."
}], "Text",
 CellChangeTimes->{{3.875993000327505*^9, 3.87599309576425*^9}, {
  3.8759931911768713`*^9, 
  3.875993207444655*^9}},ExpressionUUID->"5fe65d6c-6312-4312-b9b0-\
a3951dad5c31"],

Cell[BoxData[
 RowBox[{"DefCovD", "[", 
  RowBox[{
   RowBox[{"CDT", "[", 
    RowBox[{"-", "a"}], "]"}], ",", "TangentM", ",", 
   RowBox[{"SymbolOfCovD", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<|\>\"", ",", "\"\<\!\(\*SuperscriptBox[\(\[Del]\), \(T\)]\)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"Torsion", "->", "True"}], ",", 
   RowBox[{"FromMetric", "->", "Null"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8759932181974077`*^9, 3.875993219863757*^9}, {
  3.87599327359982*^9, 3.8759932786754932`*^9}, {3.875993337663886*^9, 
  3.875993435846468*^9}, {3.875993481914205*^9, 3.8759934969991903`*^9}, {
  3.875993543367484*^9, 3.875993576642054*^9}, {3.875993621955633*^9, 
  3.8759936562066593`*^9}, {3.8759937543201313`*^9, 3.875993759654993*^9}, {
  3.875993951521576*^9, 3.8759939560972977`*^9}, {3.875994028251598*^9, 
  3.875994028786508*^9}, {3.875994059715684*^9, 3.875994087908024*^9}},
 CellLabel->
  "In[126]:=",ExpressionUUID->"286ef907-af94-4396-873d-4903c7e80002"],

Cell[TextData[{
 "The torsion tensor of the Levi-Civita connection ",
 Cell[BoxData["CD"],
  FormatType->StandardForm,ExpressionUUID->
  "7f5226c7-b0f4-42a6-9c06-bf08a9897360"],
 " vanishes, while that of the non-adaptive ",
 Cell[BoxData["CDT"],
  FormatType->StandardForm,ExpressionUUID->
  "9a38799f-29d5-476c-9b75-21c6ac5e2ea4"],
 " is the anti-symmetric part of the corresponding Christoffel symbol."
}], "Text",
 CellChangeTimes->{{3.875994090692597*^9, 3.875994257394652*^9}, {
  3.875994323913237*^9, 
  3.875994328300764*^9}},ExpressionUUID->"c0548607-cba7-4b8d-8f35-\
6423454c3bc3"],

Cell[CellGroupData[{

