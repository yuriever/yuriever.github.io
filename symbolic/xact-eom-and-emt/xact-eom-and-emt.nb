Cell[TextData[{
 "then taking ",
 Cell[BoxData[
  RowBox[{"a1", "->", "1"}]],ExpressionUUID->
  "575297d3-399f-415e-91bb-cb6fb973055f"],
 " the equation of motion is re-written in terms of ",
 Cell[BoxData["F"],ExpressionUUID->"17eb7bd0-60c4-4890-870a-109c6139cf53"]
}], "Text",
 CellChangeTimes->{{3.875909580197472*^9, 
  3.875909586849257*^9}},ExpressionUUID->"6b560691-db90-4ad4-b7f7-\
fb1a66c8db54"],

