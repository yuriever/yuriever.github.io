     RowBox[{"2", "-", 
      InterpretationBox[
       StyleBox["d",
        ShowAutoStyles->False,
        AutoSpacing->False],
       xAct`Invar`dim,
       Editable->False]}], 
     RowBox[{"4", " ", 
      RowBox[{"(", 
