Cell[TextData[{
 "The  trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "freeScalar", "]"}]],ExpressionUUID->
  "9c65c64f-ddda-49df-b4df-f1087afd69c1"],
 " vanishes when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "2"}]],ExpressionUUID->
  "768d118b-add5-4f5a-9864-d53f7001038d"],
 ", and the traces ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "abelianGauge", "]"}]],ExpressionUUID->
  "78ff2af4-0962-44b3-ac57-0e52455f0562"],
 " and ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "fourPartialST", "]"}]],ExpressionUUID->
  "87a5c48c-d3df-4bb1-92bb-4d1319794942"],
 " vanish when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "4"}]],ExpressionUUID->
  "58d0709f-6f07-4f38-92c6-1ffaf3b0b7d8"],
 ", implying that the corresponding actions are invariant under Weyl \
transformations.\n\nThe trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "conformalScalar", "]"}]],ExpressionUUID->
  "bcba48a4-bf9b-4502-b114-3552e003e204"],
 " also vanishes on-shell after choosing the constant ",
 Cell[BoxData["cs"],ExpressionUUID->"0ebadd3c-4bbe-489f-8253-914cb568d0cb"],
 " properly:\nEMTTrace = const EOM phi\nand this can be verified by ",
 Cell[BoxData[
 "SolveConstants"],ExpressionUUID->"937fa642-3fc3-446a-bda3-0b4ae5a16592"],
 "."
}], "Text",
 CellChangeTimes->{{3.874920703690859*^9, 3.874920764450818*^9}, {
  3.874920798496543*^9, 3.874920974196226*^9}, {3.8749210500323057`*^9, 
  3.874921052155098*^9}, {3.875372843320293*^9, 3.875372848080724*^9}, {
  3.875386776043779*^9, 3.875386811575589*^9}, {3.875389441679645*^9, 
  3.875389507764138*^9}, {3.8754107023053102`*^9, 3.875410740766596*^9}, {
  3.875909225307283*^9, 3.875909226272028*^9}, {3.875909258666589*^9, 
  3.8759093474013042`*^9}, {3.875925301112587*^9, 
  3.875925305459443*^9}},ExpressionUUID->"8471c885-d064-4c34-9b1e-\
4b2a89971411"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "const", "]"}], ";"}], "\n", 
 RowBox[{"First", "@", 
  RowBox[{"SolveConstants", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"EMTTrace", "[", "conformalScalar", "]"}], "+", 
      RowBox[{"const", " ", 
       RowBox[{"EOM", "[", "conformalScalar", "]"}], 
       RowBox[{"phi", "[", "]"}]}]}], "==", "0"}], ",", "cs", ",", 
    RowBox[{"{", "const", "}"}]}], "]"}]}]}], "Code",
 CellChangeTimes->{{3.874921071025041*^9, 3.8749211028034*^9}, {
   3.874921143957095*^9, 3.874921241131291*^9}, {3.874921315774971*^9, 
   3.874921354932281*^9}, {3.874921386739418*^9, 3.874921406505157*^9}, {
