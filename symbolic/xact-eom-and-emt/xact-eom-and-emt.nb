Cell[TextData[{
 "The equation of motion and stress tensor of 4pST theory contain factors \
same as the kinematical term, which can be collected by ",
 Cell[BoxData[
 "MakeRule"],ExpressionUUID->"b6ef0f37-5fa9-4f75-9866-f0fb88a0a425"],
 "."
}], "Text",
