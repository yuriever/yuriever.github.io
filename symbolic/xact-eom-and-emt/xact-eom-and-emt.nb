Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"VarD", "[", 
    RowBox[{"tensor_", ",", "covd_"}], "]"}], "[", "expr_", "]"}]],
  ExpressionUUID->"37ab9f6f-0024-42b1-82d5-227146e8f9c3"],
 " is designed for variation. \nThe first argument specifies the varied field \
and the second specifies the covariant derivative to be integrated by parts.\n\
\nFor example, the equation of motion of free scalar is"
}], "Text",
 CellChangeTimes->{{3.8747251082514477`*^9, 3.874725143967155*^9}, {
   3.874725239711812*^9, 3.87472526868642*^9}, {3.874810277044652*^9, 
