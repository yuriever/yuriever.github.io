79df4fb9ead7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"kin", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<K\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ruleKinematic", "=", 
   RowBox[{"MakeRule", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}], " ", 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}]}], ",", 
      RowBox[{"kin", "[", "]"}]}], "}"}], "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.875387055867646*^9, 3.875387125497651*^9}, {
   3.875387165933576*^9, 3.875387170380464*^9}, {3.875387377407549*^9, 
