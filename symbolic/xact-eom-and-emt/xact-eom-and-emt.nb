Cell[TextData[{
 "The equation of motion and stress tensor of 4pST theory contain factors \
same as the kinematical term, which can be collected by ",
 Cell[BoxData[
 "MakeRule"],ExpressionUUID->"b6ef0f37-5fa9-4f75-9866-f0fb88a0a425"],
 "."
}], "Text",ExpressionUUID->"e47f86c5-91c1-4193-82ce-79df4fb9ead7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"kin", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<K\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ruleKinScalar", "=", 
   RowBox[{"MakeRule", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}], " ", 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}]}], ",", 
      RowBox[{"kin", "[", "]"}]}], "}"}], "]"}]}], ";"}]}], "Code",
 CellLabel->"In[53]:=",ExpressionUUID->"50f9c280-9ea2-45af-8c03-2a6771b08814"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"EOM", "[", "fourPartialST", "]"}], "//", "Expand"}], "//", 
  RowBox[{"ReplaceRepeated", "[", "ruleKinScalar", "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"EMT", "[", "fourPartialST", "]"}], "//", "Expand"}], "//", 
  RowBox[{"ReplaceRepeated", "[", "ruleKinScalar", "]"}]}]}], "Code",
 CellLabel->"In[55]:=",ExpressionUUID->"d8781bcd-362e-4ac7-9dbd-6af0e0ed372b"],

