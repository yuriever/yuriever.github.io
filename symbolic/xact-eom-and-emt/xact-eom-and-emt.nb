Cell[TextData[{
 "The  trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "freeScalar", "]"}]],ExpressionUUID->
  "9c65c64f-ddda-49df-b4df-f1087afd69c1"],
 " vanishes when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "2"}]],ExpressionUUID->
  "768d118b-add5-4f5a-9864-d53f7001038d"],
 ", and the traces ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "abelianGauge", "]"}]],ExpressionUUID->
  "78ff2af4-0962-44b3-ac57-0e52455f0562"],
 " and ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "fourPartialST", "]"}]],ExpressionUUID->
  "87a5c48c-d3df-4bb1-92bb-4d1319794942"],
 " vanish when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "4"}]],ExpressionUUID->
  "58d0709f-6f07-4f38-92c6-1ffaf3b0b7d8"],
 ", implying that the corresponding actions are invariant under Weyl \
transformations."
}], "Text",
 CellChangeTimes->{{3.874920703690859*^9, 3.874920764450818*^9}, {
  3.874920798496543*^9, 3.874920974196226*^9}, {3.8749210500323057`*^9, 
  3.874921052155098*^9}, {3.875372843320293*^9, 3.875372848080724*^9}, {
  3.875386776043779*^9, 3.875386811575589*^9}, {3.875389441679645*^9, 
