Cell["\<\
Now the Lagrangians of free scalar, conformal scalar, U(1) gauge field and \
four partial scalar-tensor (4pST) theories can be defined as,\
\>", "Text",ExpressionUUID->"e4c10a5c-c3c9-44c3-83c2-4df31764a65a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "action", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "kinScalar", "}"}], ",", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"kinematical", " ", "term"}], "*)"}], "\n", "\t", 
     RowBox[{
      RowBox[{"kinScalar", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"CD", "[", "a", "]"}], "@", 
         RowBox[{"phi", "[", "]"}]}], " ", 
        RowBox[{
         RowBox[{"CD", "[", 
          RowBox[{"-", "a"}], "]"}], "@", 
         RowBox[{"phi", "[", "]"}]}]}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{"action", "[", "freeScalar", "]"}], "=", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"measure", "[", "metric", "]"}], " ", "kinScalar"}]}], ";", 
      "\n", "\t", 
      RowBox[{
       RowBox[{"action", "[", "conformalScalar", "]"}], "=", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"measure", "[", "metric", "]"}], 
        RowBox[{"(", 
         RowBox[{"kinScalar", "+", 
          RowBox[{"cs", " ", 
           RowBox[{"RicciScalarCD", "[", "]"}], " ", 
           RowBox[{
            RowBox[{"phi", "[", "]"}], "^", "2"}]}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"action", "[", "abelianGauge", "]"}], "=", 
       RowBox[{
        RowBox[{"1", "/", "4"}], " ", 
        RowBox[{"measure", "[", "metric", "]"}], " ", 
        RowBox[{"F", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "b"}]}], "]"}], 
        RowBox[{"F", "[", 
         RowBox[{"a", ",", "b"}], "]"}]}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{"action", "[", "fourPartialST", "]"}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "4"}], " ", 
         RowBox[{"measure", "[", "metric", "]"}], " ", 
         RowBox[{"alpha", "@", 
          RowBox[{"phi", "[", "]"}]}], " ", 
         RowBox[{
          RowBox[{"Scalar", "[", "kinScalar", "]"}], "^", "2"}]}], "//", 
        "NoScalar"}]}], ";"}]}], "\n", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"action", "/@", "theoryList"}], "//", "TableForm"}]}], "Code",
 CellLabel->"In[33]:=",ExpressionUUID->"79932a3d-1e87-45c0-8c00-ba34e9da3dde"],

