   3.875060785139263*^9, {3.8750627987653513`*^9, 3.875062949910551*^9}, {
   3.8753890228768263`*^9, 3.875389032421939*^9}, {3.8753892127780523`*^9, 
   3.875389222867774*^9}, 
   3.875908624984079*^9},ExpressionUUID->"7c1ef0e4-c1cc-4639-a695-\
0f5dfa4fa2c0"],

