  3.8759093474013042`*^9}, {3.875925301112587*^9, 3.875925305459443*^9}, {
  3.876153274666193*^9, 
  3.876153322008808*^9}},ExpressionUUID->"8471c885-d064-4c34-9b1e-\
4b2a89971411"],

Cell[TextData[{
 "The trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "conformalScalar", "]"}]],ExpressionUUID->
  "650bff74-7793-412c-8e17-84a345172cc1"],
 " also vanishes on-shell after choosing the constant ",
 Cell[BoxData["cs"],ExpressionUUID->"18f27b8f-030d-46e0-8f9e-a602a719fb17"],
 " properly:\n\n\tEMTTrace = const EOM phi\n\nwhich can be verified by ",
 Cell[BoxData[
 "SolveConstants"],ExpressionUUID->"b6d4fee7-b0d0-4aa9-98fc-e772b58b6138"],
 "."
}], "Text",
 CellChangeTimes->{{3.874920703690859*^9, 3.874920764450818*^9}, {
  3.874920798496543*^9, 3.874920974196226*^9}, {3.8749210500323057`*^9, 
  3.874921052155098*^9}, {3.875372843320293*^9, 3.875372848080724*^9}, {
  3.875386776043779*^9, 3.875386811575589*^9}, {3.875389441679645*^9, 
