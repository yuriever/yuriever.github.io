Cell[TextData[{
 Cell[BoxData[
 "Scalar"],ExpressionUUID->"d531060d-9dd2-4421-acac-e9bf3627a12d"],
 " is a head to ensure the correct contraction of tensor powers.\n",
 Cell[BoxData[
 "NoScalar"],ExpressionUUID->"3f254c7a-df3f-4fb8-af25-ca4b3b85ef0e"],
 " will delete ",
 Cell[BoxData[
 "Scalar"],ExpressionUUID->"b6097162-1eb6-4ad5-a03f-405aa0ff134b"],
 " and put dummy indices automatically, and the inverse is ",
 Cell[BoxData[
 "PutScalar"],ExpressionUUID->"0d9f4a36-5d8c-42a2-b24b-fd00d490fb30"],
 ".\n",
 Cell[BoxData[
 "BreakScalars"],ExpressionUUID->"c06b5350-8351-474b-a464-93ff23b2b0be"],
 " will break ",
 Cell[BoxData[
 "Scalar"],ExpressionUUID->"c388c810-f1f0-4fa8-a990-5438bb6e2901"],
 " into irreducible ",
 Cell[BoxData[
 "Scalar"],ExpressionUUID->"726f296a-e4fa-4a4c-b108-b7c4dcf705a2"],
 " pieces."
}], "Text",ExpressionUUID->"e7a2272b-71a8-45d2-a65d-13fc73bfe8cf"],

Cell[TextData[{
 Cell[BoxData[
 "BreakInMonomials"],ExpressionUUID->"be4f3fe2-0327-4bae-8f9b-fd7d79a696b5"],
 " can decompose an expression into monomials, which is useful to analyse the \
structure of contractions."
}], "Text",ExpressionUUID->"3de5eaab-0336-4d06-9411-6fa1989916d0"],

