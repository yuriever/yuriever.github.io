Cell[TextData[{
 "The arguments of ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"4b39f0c1-07e4-4731-b110-f61a6213e599"],
 " are the sign of determinant, the metric and the adapted Levi-Civita \
connection. \nThe option ",
 Cell[BoxData[
 "SymbolOfCovD"],ExpressionUUID->"89f9fe22-d828-4058-9afb-6d9807629474"],
 " specifies the postfix and prefix forms of the covariant derivative.\n\n",
 StyleBox["In ",
  FontWeight->"Bold"],
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,
  FontWeight->"Bold",ExpressionUUID->"9c197d07-1dfd-4b31-8b57-61854950a4cc"],
 StyleBox[" the lower indices are marked by minus sign.",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.874664138245167*^9, 3.874664215169526*^9}, 
   3.874724760194075*^9, {3.87599290501858*^9, 
   3.8759929117143106`*^9}},ExpressionUUID->"a6483658-48a5-4da7-95f5-\
1f4068c1706e"],

Cell[TextData[{
 Cell[BoxData[
 "PrintAs"],ExpressionUUID->"c3427d3d-d4c0-48ee-9201-cfd18e8f8ee4"],
 " is a common function and option telling ",
 Cell[BoxData["xAct`"],ExpressionUUID->"566036f2-f2de-48e3-9c57-931fe41fdb8c"],
 " how to print related symbols. \nIt's convenient to print the Levi-Civita \
symbol as ",
 Cell[BoxData["\"\<\[Epsilon]\>\""],
  FormatType->StandardForm,ExpressionUUID->
  "db30b970-617f-4b9c-a843-7ca0cead4dfd"],
 ", and the Riemann tensor, Ricci tensor and Ricci scalar all as ",
 Cell[BoxData[
 "\"\<R\>\""],ExpressionUUID->"d07676be-5bfb-46e1-842a-2275b4112f08"],
 "."
}], "Text",
 CellChangeTimes->{{3.874664138245167*^9, 3.874664215169526*^9}, {
  3.875908683522744*^9, 3.875908701248767*^9}, {3.875908738758651*^9, 
  3.8759087438702507`*^9}, {3.8759929352502527`*^9, 3.875992936631572*^9}, {
  3.875995451555427*^9, 
  3.875995480007044*^9}},ExpressionUUID->"de007c75-a3b9-4568-b2ae-\
8dc11a1adc67"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RiemannCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RicciCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RicciScalarCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "epsilonmetric", "]"}], "^=", 
   "\"\<\[Epsilon]\>\""}], ";"}]}], "Code",
 CellChangeTimes->{{3.87599538417264*^9, 3.875995392997744*^9}, {
  3.87599543793311*^9, 3.875995439619279*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"1743f7c9-433c-4995-977e-2582d4e1d5d4"],

Cell[TextData[{
 "The tangent bundle ",
 Cell[BoxData[
 "TangentM"],ExpressionUUID->"edb1c05a-f04c-4976-b5f3-746013ddda03"],
 " will be automatically defined after ",
 Cell[BoxData[
 "DefManifold"],ExpressionUUID->"a9825432-48d0-4349-845a-69bcdd9bf9ca"],
 ".\nSimilarly the metric determinant ",
 Cell[BoxData[
 "Detmetric"],ExpressionUUID->"9e6d1f05-21c9-4d15-a3e1-88dac943c735"],
 " and curvature-related tensors will be defined after ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"15d9868e-c0cc-4eb8-88ed-5f60a253cda3"],
 ". \n\nThe naming of these objects obeys the following form:\n\t",
 Cell[BoxData[
  RowBox[{"\"\<key word\>\"", "<>", "\"\<parent object name\>\""}]],
  FormatType->StandardForm,ExpressionUUID->
  "d2828178-b19c-492d-b139-8b384d3371d6"]
}], "Text",
 CellChangeTimes->{{3.8746642281468687`*^9, 3.874664269491983*^9}, {
   3.874664362989695*^9, 3.874664364203846*^9}, {3.874720531168679*^9, 
   3.874720547524186*^9}, {3.8747207690256166`*^9, 3.874720772998616*^9}, 
   3.8759087139422293`*^9, 3.875908839086769*^9, {3.8759929703995743`*^9, 
   3.8759929726302977`*^9}, {3.875995498538621*^9, 3.87599550060743*^9}, {
   3.8759955562533216`*^9, 3.875995587281472*^9}, {3.8759957623227386`*^9, 
   3.875995768509201*^9}, {3.881632752141307*^9, 
   3.8816327936067133`*^9}},ExpressionUUID->"48f1b77a-40e6-4da6-b099-\
0650b9e1a6da"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"TangentM", ",", 
   RowBox[{"Detmetric", "[", "]"}], ",", 
   RowBox[{"epsilonmetric", "[", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "]"}], ",", 
   RowBox[{"RiemannCD", "[", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.874636141238605*^9, 3.8746361587762337`*^9}, {
  3.8759572106243773`*^9, 3.875957221501563*^9}, {3.8759953670882387`*^9, 
  3.875995376367579*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"46993e2f-a484-4863-8826-57913bd72d9f"],

Cell[TextData[{
 "For convenience we have introduced the function ",
 Cell[BoxData[
 "measure"],ExpressionUUID->"8ff847ce-fc83-42a7-954e-a28a3735bba5"],
 " so that ",
 Cell[BoxData[
  RowBox[{"measure", "@", "metric"}]],ExpressionUUID->
  "b45f12cc-4e70-4333-91d3-8f81d09acd0c"],
 " returns ",
 Cell[BoxData[
  RowBox[{"Sqrt", "[", 
   RowBox[{"-", 
    RowBox[{"Detmetric", "[", "]"}]}], "]"}]],ExpressionUUID->
  "d1a4c1a3-40a5-4ce0-b1b0-2513314383bf"],
 "."
}], "Text",
 CellChangeTimes->{{3.874664329546048*^9, 3.874664343402648*^9}, {
  3.875995593008184*^9, 
  3.875995594410942*^9}},ExpressionUUID->"6d72e872-4abe-4ec5-b49e-\
6a42f7958aaf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Connections and derivatives", "Subsubsection",
 CellChangeTimes->{{3.87599803983468*^9, 
  3.87599806209165*^9}},ExpressionUUID->"b09e398b-2dd0-4e26-a5f4-\
122e45322367"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
 "DefCovD"],ExpressionUUID->"abc972a6-d63e-4767-9d74-ea4ae6cbddce"],
 " is to define connections not associated to the metric or with torsion, \
which can be specified by the options ",
 Cell[BoxData[
 "Torsion"],ExpressionUUID->"c46c380b-b7cf-43c3-a028-10f3ef45303c"],
 " and ",
 Cell[BoxData[
 "FromMetric"],ExpressionUUID->"b7fa3b18-a483-4a9e-846a-11c0396f6f67"],
 " respectively. The partial derivative without curvature nor torsion is ",
 Cell[BoxData[
 "xAct`xTensor`PD"],ExpressionUUID->"b955670b-4761-4db3-9c82-fb11e6199807"],
 "."
}], "Text",
 CellChangeTimes->{{3.875993000327505*^9, 3.87599309576425*^9}, {
  3.8759931911768713`*^9, 3.875993207444655*^9}, {3.8761529649692507`*^9, 
  3.876152965741407*^9}, {3.881631925182705*^9, 
  3.8816319310847816`*^9}},ExpressionUUID->"5fe65d6c-6312-4312-b9b0-\
a3951dad5c31"],

Cell[BoxData[
 RowBox[{"DefCovD", "[", 
  RowBox[{
   RowBox[{"CDT", "[", 
    RowBox[{"-", "a"}], "]"}], ",", "TangentM", ",", 
   RowBox[{"SymbolOfCovD", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<|\>\"", ",", "\"\<\!\(\*SuperscriptBox[\(\[Del]\), \(T\)]\)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"Torsion", "->", "True"}], ",", 
   RowBox[{"FromMetric", "->", "Null"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.8759932181974077`*^9, 3.875993219863757*^9}, {
  3.87599327359982*^9, 3.8759932786754932`*^9}, {3.875993337663886*^9, 
  3.875993435846468*^9}, {3.875993481914205*^9, 3.8759934969991903`*^9}, {
  3.875993543367484*^9, 3.875993576642054*^9}, {3.875993621955633*^9, 
  3.8759936562066593`*^9}, {3.8759937543201313`*^9, 3.875993759654993*^9}, {
  3.875993951521576*^9, 3.8759939560972977`*^9}, {3.875994028251598*^9, 
  3.875994028786508*^9}, {3.875994059715684*^9, 3.875994087908024*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"286ef907-af94-4396-873d-4903c7e80002"],

Cell[TextData[{
 "The torsion tensor of the Levi-Civita connection ",
 Cell[BoxData["CD"],
  FormatType->StandardForm,ExpressionUUID->
  "7f5226c7-b0f4-42a6-9c06-bf08a9897360"],
 " vanishes, while that of the non-adapted ",
 Cell[BoxData["CDT"],
  FormatType->StandardForm,ExpressionUUID->
  "9a38799f-29d5-476c-9b75-21c6ac5e2ea4"],
 " is the anti-symmetric part of the corresponding Christoffel symbol."
}], "Text",
 CellChangeTimes->{{3.875994090692597*^9, 3.875994257394652*^9}, {
  3.875994323913237*^9, 3.875994328300764*^9}, {3.876004559924181*^9, 
  3.876004560650159*^9}},ExpressionUUID->"c0548607-cba7-4b8d-8f35-\
6423454c3bc3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"TorsionCD", "[", 
   RowBox[{"a", ",", 
    RowBox[{"-", "b"}], ",", 
    RowBox[{"-", "c"}]}], "]"}], "//", 
  "TorsionToChristoffel"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TorsionCDT", "[", 
   RowBox[{"a", ",", 
    RowBox[{"-", "b"}], ",", 
    RowBox[{"-", "c"}]}], "]"}], "//", "TorsionToChristoffel"}]}], "Input",
 CellChangeTimes->{{3.875994259598835*^9, 3.875994260672805*^9}, {
  3.875994313581995*^9, 3.8759943157958727`*^9}, {3.876151509687731*^9, 
  3.87615151011762*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"4c2d4f5d-9138-4327-94d4-d2e9ece9b0c8"],

Cell[TextData[{
 Cell[BoxData["CDT"],ExpressionUUID->"ef2173a9-a92a-4c5c-a743-3c4c77931487"],
 " is irrelevant to the following discussion and are undefined by"
}], "Text",
 CellChangeTimes->{{3.8759942737165413`*^9, 3.8759943062165527`*^9}, {
  3.875994349917673*^9, 3.875994417793882*^9}, {3.8816328599123697`*^9, 
  3.881632860176791*^9}},ExpressionUUID->"7ac2e404-22a6-4193-bbab-\
b240a0d3edee"],

Cell[BoxData[
 RowBox[{"UndefCovD", "@", "CDT"}]], "Input",
 CellChangeTimes->{{3.875994419023644*^9, 3.8759944252855377`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"9d544a3e-1165-4f80-b226-e581308de676"]
}, Open  ]],

Cell[CellGroupData[{

Cell["User-defined vector fields", "Subsubsection",
 CellChangeTimes->{{3.8746357241064863`*^9, 
  3.874635737007299*^9}},ExpressionUUID->"7a0e1b12-722b-4d36-9c58-\
2ab1db4b6970"],

Cell[TextData[{
 "User-defined vector fields:\n\n",
 Cell[BoxData[
 "\[Phi]"],ExpressionUUID->"9edee7a0-b1fb-413b-b86d-6286b64217ba"],
 "\t\tscalar field\n",
 Cell[BoxData["A"],ExpressionUUID->"de2711fd-8301-46e1-86fe-4f26478b7eb9"],
 "\t\tU(1) gauge potential\n",
 Cell[BoxData["F"],ExpressionUUID->"62af137f-754d-49df-aa54-54fa2a8100cf"],
 "\t\tU(1) field strength\n",
 Cell[BoxData["cs"],ExpressionUUID->"56d4ab57-01e7-4a3c-9b45-e113ac924bdf"],
 "\t\tconstant\n",
 Cell[BoxData["alpha"],ExpressionUUID->"f4c7d27e-1582-4429-8f8b-c9273c67e22c"],
 "\tscalar function of field"
}], "Text",
 CellChangeTimes->{{3.874314121713806*^9, 3.874314131051128*^9}, {
  3.874318217149967*^9, 3.874318217406749*^9}, {3.874635933156583*^9, 
  3.87463608786124*^9}, {3.874636331559537*^9, 3.874636380102828*^9}, {
  3.874664404173562*^9, 3.87466445080226*^9}, {3.874720570497046*^9, 
  3.874720571462428*^9}, {3.875024558056594*^9, 3.875024594905451*^9}, {
  3.8750678429075947`*^9, 3.875067851126099*^9}, {3.876153112500478*^9, 
  3.8761531140850286`*^9}},ExpressionUUID->"4ec77c61-e4d8-439d-aa8c-\
82f018b1768d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"phi", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Phi]\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], ",", "M"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "M", ",", 
    RowBox[{"Antisymmetric", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"cs", ",", 
    RowBox[{"PrintAs", "->", "\"\<c\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefScalarFunction", "[", 
   RowBox[{"alpha", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Alpha]\>\""}]}], "]"}], ";"}]}], "Code",
 CellChangeTimes->{{3.8605836567214136`*^9, 3.860583663333129*^9}, {
   3.860583786180087*^9, 3.8605837869832177`*^9}, {3.860583819074193*^9, 
   3.86058381924725*^9}, {3.8606126849646597`*^9, 3.860612758186241*^9}, {
   3.8606129002557545`*^9, 3.8606129093232894`*^9}, {3.8606134418759995`*^9, 
   3.860613442044799*^9}, {3.860613479662074*^9, 3.8606135095757723`*^9}, {
   3.86061354552407*^9, 3.8606135456921935`*^9}, {3.8611153393215027`*^9, 
   3.861115343924569*^9}, {3.861126706997135*^9, 3.861126707821253*^9}, {
   3.861126822935961*^9, 3.8611268397807207`*^9}, {3.8629001497438917`*^9, 
   3.862900150801654*^9}, {3.8637270794852*^9, 3.863727097084691*^9}, {
   3.874148078717531*^9, 3.874148082080945*^9}, {3.874148157676219*^9, 
   3.8741481650522957`*^9}, {3.8742900944842873`*^9, 3.874290094662088*^9}, {
   3.8743152216312923`*^9, 3.874315239394269*^9}, 3.8743354187378073`*^9, {
   3.874636384511845*^9, 3.874636386892128*^9}, {3.875024552232512*^9, 
   3.875024553018675*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"74d6e2b4-a2f8-4ee4-b81d-2bb5b3a84815"],

Cell[TextData[{
 "We need a method to impose the relation between gauge potential and field \
strength:\n\n\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"a", ",", "b"}], "]"}], "->", 
   RowBox[{
    RowBox[{
     RowBox[{"CD", "[", "a", "]"}], "@", 
     RowBox[{"A", "[", "b", "]"}]}], "-", 
    RowBox[{
     RowBox[{"CD", "[", "b", "]"}], "@", 
     RowBox[{"A", "[", "a", "]"}]}]}]}]],ExpressionUUID->
  "4803691d-4573-4a8d-9287-c6d60aacc223"]
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
  3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
  3.874722729770549*^9}, {3.874724859840152*^9, 3.874724865651198*^9}, {
  3.875012948497933*^9, 3.875012949217291*^9}, {3.875012995588451*^9, 
  3.875012996410304*^9}, {3.875014629537278*^9, 3.8750146563444567`*^9}, {
  3.875028455754752*^9, 3.875028466439206*^9}, {3.8750678641882143`*^9, 
  3.875067876716927*^9}, {3.875995839266363*^9, 
  3.8759958462563457`*^9}},ExpressionUUID->"382e7d32-e114-4d65-8f00-\
2fb548b471d4"],

Cell[TextData[{
 "In Mathematica there are roughly two methods of converting expressions: ",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d688371f-c956-4363-8856-ec08cca76397"],
 " vs. ",
 Cell[BoxData["Set"],ExpressionUUID->"dbc6129c-3380-4f73-b7c9-8a2c97841d05"],
 ", see e.g. the documentation on the standard evaluation sequence: ",
 Cell[BoxData[
  RowBox[{"tutorial", "/", "Evaluation"}]],ExpressionUUID->
  "2464932b-9998-4d6b-bdad-468e4ec445b7"],
 ". \n",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d746d8da-d962-4581-83ad-66350b978205"],
 " is more finer than ",
 Cell[BoxData["Set"],ExpressionUUID->"98019db5-b750-44fa-b9e9-e1f3b484d2e3"],
 " for controlling the evaluation: the user can determine whether to apply \
rules or not, while relations by ",
 Cell[BoxData["Set"],ExpressionUUID->"b44ea15f-3479-4037-b3a0-df0566e98886"],
 " will always be applied automatically."
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
   3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
   3.874722729770549*^9}, {3.874724859840152*^9, 3.874724865651198*^9}, 
   3.875012948497933*^9, {3.8750129851573563`*^9, 3.87501298623281*^9}, {
   3.875013016621004*^9, 3.875013052631103*^9}, {3.875013125441889*^9, 
   3.875013138389717*^9}, {3.87501342579502*^9, 3.8750134680703697`*^9}, {
   3.875013915051552*^9, 3.875013942283339*^9}, {3.875014041092051*^9, 
   3.875014105487253*^9}, {3.8750141455627537`*^9, 3.875014172739987*^9}, {
   3.875014274965941*^9, 3.875014294743494*^9}, {3.875014385062654*^9, 
   3.875014390177971*^9}, {3.875014420459053*^9, 3.875014518168043*^9}, 
   3.875014550814077*^9, {3.875014693070177*^9, 3.875014708653754*^9}, {
   3.875014812555884*^9, 3.875014838119796*^9}, {3.875014887460134*^9, 
   3.8750149093746*^9}, {3.87501495612033*^9, 3.8750150240701513`*^9}, 
   3.875015101209065*^9, {3.875021054566197*^9, 3.875021055557321*^9}, {
   3.8759087752563467`*^9, 3.8759087963250093`*^9}, 3.8759961335459957`*^9, {
   3.876153142463333*^9, 
   3.8761531482567787`*^9}},ExpressionUUID->"6e9b587f-2a5b-4f9c-8084-\
67064da370ea"],

Cell[TextData[{
 Cell[BoxData["xAct`"],ExpressionUUID->"c3f7ae34-7b74-47c6-8e5d-3e1b09d231f3"],
 " provides analogous functions ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"50c6e84e-bdea-4210-a6c8-ed5a60e5b452"],
 " vs. ",
 Cell[BoxData[
 "IndexSet"],ExpressionUUID->"0c410c8d-569d-4ce3-a11d-97f3a32fec94"],
 ", and their delayed versions ",
 Cell[BoxData[
 "IndexRuleDelayed"],ExpressionUUID->"3b4755d0-d008-4675-b9cd-4f2e5ac4e4ca"],
 " vs. ",
 Cell[BoxData[
 "IndexSetDelayed"],ExpressionUUID->"756d33c4-4e2a-4ba0-8da8-29165e2a029f"],
 ". \nWhen pattern matching, the ",
 Cell[BoxData[
 "\"\<*IndexQ\>\""],ExpressionUUID->"5de84aac-bf8c-48e2-8b32-54ec83f67dc7"],
 "-family can help to specify index types."
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
   3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
   3.874722729770549*^9}, {3.874724859840152*^9, 3.874724865651198*^9}, 
   3.875012948497933*^9, {3.8750129851573563`*^9, 3.87501298623281*^9}, {
   3.875013016621004*^9, 3.875013052631103*^9}, {3.875013125441889*^9, 
   3.875013138389717*^9}, {3.87501342579502*^9, 3.8750134680703697`*^9}, {
   3.875013915051552*^9, 3.875013942283339*^9}, {3.875014041092051*^9, 
   3.875014105487253*^9}, {3.8750141455627537`*^9, 3.875014172739987*^9}, {
   3.875014274965941*^9, 3.875014294743494*^9}, {3.875014385062654*^9, 
   3.875014390177971*^9}, {3.875014420459053*^9, 3.875014518168043*^9}, 
   3.875014550814077*^9, {3.875014693070177*^9, 3.875014708653754*^9}, {
   3.875021084990657*^9, 3.875021097010482*^9}, {3.875908800815331*^9, 
   3.8759088233772163`*^9}, 
   3.87599613694039*^9},ExpressionUUID->"4ad50534-4edc-4515-8a2e-\
9a9e79d5a019"],

Cell[BoxData[
 RowBox[{"Names", "[", "\"\<xAct`xTensor`*IndexQ\>\"", "]"}]], "Input",
 CellChangeTimes->{{3.875014229644462*^9, 3.875014255739369*^9}, {
  3.875060740611363*^9, 3.875060741243099*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"448a55b0-03e0-4fb6-9f84-279f1f6f9f33"],

Cell[TextData[{
 "Built on ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"452f4f31-2d54-4117-b98f-b203b77cc2b8"],
 ", ",
 Cell[BoxData[
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{"LHS_", ",", "RHS_", ",", "conditions___"}], "}"}], "]"}]],
  ExpressionUUID->"de03bfa3-99cc-4796-8db4-6554c9579a37"],
 " provides more functionalities like checking index balance and taking \
account of tensor symmetry and metric contraction, which can be turned by \
options."
}], "Text",
