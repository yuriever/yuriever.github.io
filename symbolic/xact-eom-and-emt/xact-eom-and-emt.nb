Cell[BoxData[
 RowBox[{"ruleFToA", "=", 
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"F", "[", 
      RowBox[{"a", ",", "b"}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"CD", "[", "a", "]"}], "@", 
       RowBox[{"A", "[", "b", "]"}]}], "-", 
      RowBox[{
       RowBox[{"CD", "[", "b", "]"}], "@", 
       RowBox[{"A", "[", "a", "]"}]}]}]}], "}"}], "]"}]}]], "Code",
 CellChangeTimes->{
  3.863807846054927*^9, {3.863808049597301*^9, 3.8638080511416063`*^9}, {
