Cell[BoxData[
 RowBox[{"ruleFToA", "=", 
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"F", "[", 
      RowBox[{"a", ",", "b"}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"CD", "[", "a", "]"}], "@", 
       RowBox[{"A", "[", "b", "]"}]}], "-", 
      RowBox[{
       RowBox[{"CD", "[", "b", "]"}], "@", 
       RowBox[{"A", "[", "a", "]"}]}]}]}], "}"}], "]"}]}]], "Code",
 CellChangeTimes->{
