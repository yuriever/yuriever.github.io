  3.8759091528496513`*^9, 
  3.8759091537887983`*^9}},ExpressionUUID->"e47f86c5-91c1-4193-82ce-\
79df4fb9ead7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"kin", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<K\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ruleKinScalar", "=", 
   RowBox[{"MakeRule", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}], " ", 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}]}], ",", 
      RowBox[{"kin", "[", "]"}]}], "}"}], "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.875387055867646*^9, 3.875387125497651*^9}, {
   3.875387165933576*^9, 3.875387170380464*^9}, {3.875387377407549*^9, 
