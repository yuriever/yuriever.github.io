Cell["\<\
Now the Lagrangians of free scalar, conformal scalar, U(1) gauge field and \
four partial scalar-tensor (4pST) theories can be defined as,\
\>", "Text",
 CellChangeTimes->{{3.8747228639268923`*^9, 3.8747229273644123`*^9}, {
   3.8748102424816236`*^9, 3.874810243717366*^9}, {3.874996859768487*^9, 
   3.8749968728890057`*^9}, {3.875008981559885*^9, 3.875009007137476*^9}, 
   3.8750245149327602`*^9, {3.875372069450502*^9, 3.875372110189829*^9}, {
   3.875389115066379*^9, 3.875389118570162*^9}, {3.8759091632092876`*^9, 
   3.875909166463138*^9}},ExpressionUUID->"e4c10a5c-c3c9-44c3-83c2-\
4df31764a65a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "kinematic", "}"}], ",", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"kinematical", " ", "term"}], "*)"}], "\n", "\t", 
     RowBox[{
      RowBox[{"kinematic", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"CD", "[", "a", "]"}], "@", 
         RowBox[{"phi", "[", "]"}]}], " ", 
        RowBox[{
         RowBox[{"CD", "[", 
          RowBox[{"-", "a"}], "]"}], "@", 
         RowBox[{"phi", "[", "]"}]}]}]}], ";", "\n", "\t", 
      RowBox[{"(*", 
       RowBox[{
       "associate", " ", "the", " ", "actions", " ", "to", " ", "the", " ", 
        "theory", " ", "names", " ", "by", " ", "UpSet"}], "*)"}], "\n", "\t", 
      RowBox[{
       RowBox[{"action", "[", "freeScalar", "]"}], "^=", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"measure", "@", "metric"}], " ", "kinematic"}]}], ";", "\n", 
      "\t", 
      RowBox[{
       RowBox[{"action", "[", "conformalScalar", "]"}], "^=", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"measure", "@", "metric"}], 
        RowBox[{"(", 
         RowBox[{"kinematic", "+", 
          RowBox[{"cs", " ", 
           RowBox[{"RicciScalarCD", "[", "]"}], " ", 
           RowBox[{
            RowBox[{"phi", "[", "]"}], "^", "2"}]}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"action", "[", "abelianGauge", "]"}], "^=", 
       RowBox[{
        RowBox[{"1", "/", "4"}], " ", 
        RowBox[{"measure", "@", "metric"}], " ", 
        RowBox[{"F", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "b"}]}], "]"}], 
        RowBox[{"F", "[", 
         RowBox[{"a", ",", "b"}], "]"}]}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{"action", "[", "fourPartialST", "]"}], "^=", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "4"}], " ", 
         RowBox[{"measure", "@", "metric"}], " ", 
         RowBox[{"alpha", "@", 
          RowBox[{"phi", "[", "]"}]}], " ", 
         RowBox[{
          RowBox[{"Scalar", "[", "kinematic", "]"}], "^", "2"}]}], "//", 
        "NoScalar"}]}], ";"}]}], "\n", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{"action", "[", "freeScalar", "]"}], "\n", 
 RowBox[{"action", "[", "conformalScalar", "]"}], "\n", 
 RowBox[{"action", "[", "abelianGauge", "]"}], "\n", 
 RowBox[{"action", "[", "fourPartialST", "]"}]}], "Code",
 CellChangeTimes->{
  3.863807846054927*^9, {3.863808049597301*^9, 3.8638080511416063`*^9}, {
