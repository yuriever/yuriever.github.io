Cell[CellGroupData[{

Cell["User-defined vector fields", "Subsubsection",ExpressionUUID->"7a0e1b12-722b-4d36-9c58-2ab1db4b6970"],

Cell[TextData[{
 "User-defined vector fields:\n\n",
 Cell[BoxData[
 "\[Phi]"],ExpressionUUID->"9edee7a0-b1fb-413b-b86d-6286b64217ba"],
 "\t\tscalar field\n",
 Cell[BoxData["A"],ExpressionUUID->"de2711fd-8301-46e1-86fe-4f26478b7eb9"],
 "\t\tU(1) gauge potential\n",
 Cell[BoxData["F"],ExpressionUUID->"62af137f-754d-49df-aa54-54fa2a8100cf"],
 "\t\tU(1) field strength\n",
 Cell[BoxData["cs"],ExpressionUUID->"56d4ab57-01e7-4a3c-9b45-e113ac924bdf"],
 "\t\tconstant\n",
 Cell[BoxData["alpha"],ExpressionUUID->"f4c7d27e-1582-4429-8f8b-c9273c67e22c"],
 "\tscalar function of field"
}], "Text",ExpressionUUID->"4ec77c61-e4d8-439d-aa8c-82f018b1768d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"phi", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Phi]\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], ",", "M"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "M", ",", 
    RowBox[{"Antisymmetric", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"cs", ",", 
    RowBox[{"PrintAs", "->", "\"\<c\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefScalarFunction", "[", 
   RowBox[{"alpha", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Alpha]\>\""}]}], "]"}], ";"}]}], "Code",
 CellLabel->"In[23]:=",ExpressionUUID->"74d6e2b4-a2f8-4ee4-b81d-2bb5b3a84815"],

Cell[TextData[{
 "We need a method to impose the relation between gauge potential and field \
strength:\n\n\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"a", ",", "b"}], "]"}], "->", 
   RowBox[{
    RowBox[{
     RowBox[{"CD", "[", "a", "]"}], "@", 
     RowBox[{"A", "[", "b", "]"}]}], "-", 
    RowBox[{
     RowBox[{"CD", "[", "b", "]"}], "@", 
     RowBox[{"A", "[", "a", "]"}]}]}]}]],ExpressionUUID->
  "4803691d-4573-4a8d-9287-c6d60aacc223"]
}], "Text",ExpressionUUID->"382e7d32-e114-4d65-8f00-2fb548b471d4"],

Cell[TextData[{
 "In Mathematica there are roughly two methods of converting expressions: ",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d688371f-c956-4363-8856-ec08cca76397"],
 " vs. ",
 Cell[BoxData["Set"],ExpressionUUID->"dbc6129c-3380-4f73-b7c9-8a2c97841d05"],
 ", see e.g. the documentation on the standard evaluation sequence: ",
 Cell[BoxData[
  RowBox[{"tutorial", "/", "Evaluation"}]],ExpressionUUID->
  "2464932b-9998-4d6b-bdad-468e4ec445b7"],
 ". \n",
 Cell[BoxData[
 "Rule"],ExpressionUUID->"d746d8da-d962-4581-83ad-66350b978205"],
 " is more finer than ",
 Cell[BoxData["Set"],ExpressionUUID->"98019db5-b750-44fa-b9e9-e1f3b484d2e3"],
 " for controlling the evaluation: the user can determine whether to apply \
rules or not, while relations by ",
 Cell[BoxData["Set"],ExpressionUUID->"b44ea15f-3479-4037-b3a0-df0566e98886"],
 " will always be applied automatically."
}], "Text",ExpressionUUID->"6e9b587f-2a5b-4f9c-8084-67064da370ea"],

Cell[TextData[{
 Cell[BoxData["xAct`"],ExpressionUUID->"c3f7ae34-7b74-47c6-8e5d-3e1b09d231f3"],
 " provides analogous functions ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"50c6e84e-bdea-4210-a6c8-ed5a60e5b452"],
 " vs. ",
 Cell[BoxData[
 "IndexSet"],ExpressionUUID->"0c410c8d-569d-4ce3-a11d-97f3a32fec94"],
 ", and their delayed versions ",
 Cell[BoxData[
 "IndexRuleDelayed"],ExpressionUUID->"3b4755d0-d008-4675-b9cd-4f2e5ac4e4ca"],
 " vs. ",
 Cell[BoxData[
 "IndexSetDelayed"],ExpressionUUID->"756d33c4-4e2a-4ba0-8da8-29165e2a029f"],
 ". \nWhen pattern matching, the ",
 Cell[BoxData[
 "\"\<*IndexQ\>\""],ExpressionUUID->"5de84aac-bf8c-48e2-8b32-54ec83f67dc7"],
 "-family can help to specify index types."
}], "Text",ExpressionUUID->"4ad50534-4edc-4515-8a2e-9a9e79d5a019"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Names", "[", "\"\<xAct`xTensor`*IndexQ\>\"", "]"}]], "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"448a55b0-03e0-4fb6-9f84-279f1f6f9f33"],

Cell[BoxData[
 RowBox[{"{", 
