Cell[TextData[{
 "For convenience we have introduced the function ",
 Cell[BoxData[
 "measure"],ExpressionUUID->"8ff847ce-fc83-42a7-954e-a28a3735bba5"],
 " so that ",
 Cell[BoxData[
  RowBox[{"measure", "@", "metric"}]],ExpressionUUID->
  "b45f12cc-4e70-4333-91d3-8f81d09acd0c"],
 " returns ",
 Cell[BoxData[
  RowBox[{"Sqrt", "[", 
   RowBox[{"-", 
    RowBox[{"Detmetric", "[", "]"}]}], "]"}]],ExpressionUUID->
  "d1a4c1a3-40a5-4ce0-b1b0-2513314383bf"],
 "."
}], "Text",ExpressionUUID->"6d72e872-4abe-4ec5-b49e-6a42f7958aaf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Connections and derivatives", "Subsubsection",ExpressionUUID->"b09e398b-2dd0-4e26-a5f4-122e45322367"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
 "DefCovD"],ExpressionUUID->"abc972a6-d63e-4767-9d74-ea4ae6cbddce"],
 " is to define connections not associated to the metric or with torsion, \
which can be specified by the options ",
 Cell[BoxData[
 "Torsion"],ExpressionUUID->"c46c380b-b7cf-43c3-a028-10f3ef45303c"],
 " and ",
 Cell[BoxData[
 "FromMetric"],ExpressionUUID->"b7fa3b18-a483-4a9e-846a-11c0396f6f67"],
 " respectively. The partial derivative without curvature nor torsion is ",
 Cell[BoxData[
 "xAct`xTensor`PD"],ExpressionUUID->"b955670b-4761-4db3-9c82-fb11e6199807"],
 "."
}], "Text",ExpressionUUID->"5fe65d6c-6312-4312-b9b0-a3951dad5c31"],

Cell[BoxData[
 RowBox[{"DefCovD", "[", 
  RowBox[{
   RowBox[{"CDT", "[", 
    RowBox[{"-", "a"}], "]"}], ",", "TangentM", ",", 
   RowBox[{"SymbolOfCovD", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<|\>\"", ",", "\"\<\!\(\*SuperscriptBox[\(\[Del]\), \(T\)]\)\>\""}], 
     "}"}]}], ",", 
   RowBox[{"Torsion", "->", "True"}], ",", 
   RowBox[{"FromMetric", "->", "Null"}]}], "]"}]], "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"286ef907-af94-4396-873d-4903c7e80002"],

Cell[TextData[{
 "The torsion tensor of the Levi-Civita connection ",
 Cell[BoxData["CD"],ExpressionUUID->"7f5226c7-b0f4-42a6-9c06-bf08a9897360"],
 " vanishes, while that of the non-adapted ",
 Cell[BoxData["CDT"],ExpressionUUID->"9a38799f-29d5-476c-9b75-21c6ac5e2ea4"],
 " is the anti-symmetric part of the corresponding Christoffel symbol."
}], "Text",ExpressionUUID->"c0548607-cba7-4b8d-8f35-6423454c3bc3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"TorsionCD", "[", 
   RowBox[{"a", ",", 
    RowBox[{"-", "b"}], ",", 
    RowBox[{"-", "c"}]}], "]"}], "//", 
  "TorsionToChristoffel"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TorsionCDT", "[", 
   RowBox[{"a", ",", 
    RowBox[{"-", "b"}], ",", 
    RowBox[{"-", "c"}]}], "]"}], "//", "TorsionToChristoffel"}]}], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"4c2d4f5d-9138-4327-94d4-d2e9ece9b0c8"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[20]=",ExpressionUUID->"e043d995-c799-4149-aadc-854a664447ee"],

