Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Off", "[", 
   RowBox[{"Solve", "::", "svars"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ansatzSolution", "[", "\"\<EOM\>\"", "]"}], "=", 
  RowBox[{"First", "@", 
   RowBox[{"SolveConstants", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ansatz", "[", "\"\<EOM\>\"", "]"}], "/.", "ruleFToA"}], ")"}],
      "==", 
