 RowBox[{
  RowBox[{
   InterpretationBox[
    StyleBox[
     SubsuperscriptBox["a", "1", ""],
     ShowAutoStyles->False,
     AutoSpacing->False],
    $CellContext`a1,
    Editable->False], " ", 
   InterpretationBox[
    StyleBox[
     RowBox[{
      SubscriptBox["\[Del]", "b"], GridBox[{
        {"F", 
         StyleBox[GridBox[{
            {"a", "b"},
            {" ", " "}
           },
