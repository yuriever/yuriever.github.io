Cell[TextData[{
 "The  trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "freeScalar", "]"}]],ExpressionUUID->
  "9c65c64f-ddda-49df-b4df-f1087afd69c1"],
 " vanishes when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "2"}]],ExpressionUUID->
  "768d118b-add5-4f5a-9864-d53f7001038d"],
 ", and the traces ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "abelianGauge", "]"}]],ExpressionUUID->
  "78ff2af4-0962-44b3-ac57-0e52455f0562"],
 " and ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "fourPartialST", "]"}]],ExpressionUUID->
  "87a5c48c-d3df-4bb1-92bb-4d1319794942"],
 " vanish when ",
 Cell[BoxData[
  RowBox[{"dim", "==", "4"}]],ExpressionUUID->
  "58d0709f-6f07-4f38-92c6-1ffaf3b0b7d8"],
 ", implying that the corresponding actions are invariant under Weyl \
transformations."
}], "Text",ExpressionUUID->"8471c885-d064-4c34-9b1e-4b2a89971411"],

Cell[TextData[{
 "The trace ",
 Cell[BoxData[
  RowBox[{"EMTTrace", "[", "conformalScalar", "]"}]],ExpressionUUID->
  "650bff74-7793-412c-8e17-84a345172cc1"],
 " also vanishes on-shell after choosing the constant ",
 Cell[BoxData["cs"],ExpressionUUID->"18f27b8f-030d-46e0-8f9e-a602a719fb17"],
 " properly:\n\n\tEMTTrace = const EOM phi\n\nwhich can be verified by ",
 Cell[BoxData[
 "SolveConstants"],ExpressionUUID->"b6d4fee7-b0d0-4aa9-98fc-e772b58b6138"],
 "."
}], "Text",ExpressionUUID->"0ea236a0-37c5-4d98-9b81-4080e7d22a84"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "const", "]"}], ";"}], "\n", 
 RowBox[{"First", "@", 
  RowBox[{"SolveConstants", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"EMTTrace", "[", "conformalScalar", "]"}], "+", 
      RowBox[{"const", " ", 
       RowBox[{"EOM", "[", "conformalScalar", "]"}], 
       RowBox[{"phi", "[", "]"}]}]}], "==", "0"}], ",", "cs", ",", 
    RowBox[{"{", "const", "}"}]}], "]"}]}]}], "Code",
 CellLabel->"In[58]:=",ExpressionUUID->"22635447-7576-4bc2-bd61-c4e018ca1538"],

