Notebook[{

Cell[CellGroupData[{
Cell["Packages and pre-defined functions", "Subsection",ExpressionUUID->"c570a0e4-d6b6-4618-bd79-701f481359da"],

Cell["The packages and pre-defined functions are listed below.", "Text",ExpressionUUID->"7c820f07-8f89-4c2d-ba2a-771f7ea6e4ca"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}], " ", "=", " ", 
    RowBox[{"{", "\n", "    ", 
     RowBox[{
     "\"\<xAct`xPerm`\>\"", ",", "\n", "    ", "\"\<xAct`xTensor`\>\"", ",", 
      "\n", "    ", "\"\<xAct`xPert`\>\"", ",", "\n", "    ", 
      "\"\<xAct`Invar`\>\"", ",", "\n", "    ", "\"\<xAct`xCoba`\>\"", ",", 
      "\n", "    ", "\"\<xAct`SymManipulator`\>\"", ",", "\n", "    ", 
      "\"\<xAct`xTras`\>\"", ",", "\n", "    ", "\"\<xAct`TexAct`\>\""}], 
     "\n", "}"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "version", " ", "messages", " ", "using", " ", 
    "Block"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Block", "[", " ", 
    RowBox[{
     RowBox[{"{", "Print", "}"}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"Needs", "/@", 
       RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}]}], ";"}]}], "\n", 
    "]"}], ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "dollar", " ", "symbols", " ", "of", " ", "local",
     " ", "variables"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "System`$PrePrint", " ", "=", " ", "xAct`xTensor`ScreenDollarIndices"}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "extend", " ", "ScreenDollarIndices", " ", "compatible", " ", "with", " ", 
    "Column", " ", "and", " ", "TableForm"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Unprotect", "@", "xAct`xTensor`ScreenDollarIndices"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xAct`xTensor`ScreenDollarIndices", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"head", ":", 
       RowBox[{"Column", "|", "TableForm"}]}], ")"}], "[", "x___", "]"}], 
    "]"}], " ", ":=", "\n", "    ", 
   RowBox[{"head", "@", 
    RowBox[{"xAct`xTensor`ScreenDollarIndices", "@", "x"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Protect", "@", "xAct`xTensor`ScreenDollarIndices"}], ";"}], "\n", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{
   "hide", " ", "the", " ", "definition", " ", "messages", " ", "of", " ", 
    "objects"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xAct`xTensor`$DefInfoQ", " ", "=", " ", "False"}], ";"}], "\n", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{
   "print", " ", "the", " ", "covariant", " ", "derivatives", " ", "as", " ", 
    "prefix"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"xAct`xTensor`$CovDFormat", " ", "=", " ", "\"\<Prefix\>\""}], 
  ";"}]}], "Code",
 CellLabel->"In[1]:=",ExpressionUUID->"b9cdd643-0cbe-4039-9968-fc003bf3fd01"],

Cell[TextData[{
 "For ",
 Cell[BoxData["xAct`"],ExpressionUUID->"b1257005-72f2-47b8-90f8-bdced5484d66"],
 " packages ",
 Cell[BoxData["Needs"],ExpressionUUID->"4d64961e-4325-446b-b511-d2925f8c9c9d"],
 " is better than ",
 Cell[BoxData["Get"],ExpressionUUID->"add93fc4-874f-45ca-99c7-b1d9e60c79b8"],
 ". Besides there are conflict symbols in ",
 Cell[BoxData["xAct`"],ExpressionUUID->"aac9ba83-8d3e-4513-8d54-56acfba96e6c"],
 " and ",
 Cell[BoxData[
  RowBox[{"System`", "/", "GeneralUtilities`"}]],ExpressionUUID->
  "89144ee2-fc3b-4679-88e8-f88bb10c52d8"],
 ".\nThe context specification like ",
 Cell[BoxData[
 "xAct`xTensor`"],ExpressionUUID->"11dbe532-3cbb-44cf-9ad3-7dc84912ad07"],
 " is not necessary when working in notebook."
}], "Text",ExpressionUUID->"b3749d1d-d8d6-4fa8-a07c-dbf6a79cd6da"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"measure", "::", "usage"}], " ", "=", " ", "\"\<Sqrt[-g]\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"tensorSim", "::", "usage"}], " ", "=", " ", 
    "\"\<x//ContractMetric//Simplification, Simplification = ToCanonical + \
Simplify\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"measure", "[", 
     RowBox[{"metric_", "?", "xAct`xTensor`MetricQ"}], "]"}], " ", ":=", "\n",
     "    ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"xAct`xTensor`SignDetOfMetric", "@", "metric"}], " ", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"\"\<Det\>\"", "<>", 
        RowBox[{"ToString", "@", "metric"}], "<>", "\"\<[]\>\""}], "]"}]}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tensorSim", "[", "expr_", "]"}], " ", ":=", "\n", "    ", 
   RowBox[{
    RowBox[{"expr", "//", "xAct`xTensor`ContractMetric"}], "//", 
    "xAct`xTensor`Simplification"}]}], ";"}]}], "Code",
 CellLabel->"In[8]:=",ExpressionUUID->"71970fbf-eecf-464f-9678-33d14a400cac"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{"measure", "[", "metric_", "]"}]],ExpressionUUID->
  "3f7a233b-6ed4-42b7-9760-4ebe836f0cbc"],
 " is to give the square root of metric determinant, and ",
 Cell[BoxData[
  RowBox[{"tensorSim", "[", "expr_", "]"}]],ExpressionUUID->
  "43c0edcb-1d61-47e8-94aa-e82b5a1cef27"],
 " is useful for simplifying expressions, in which Simplification = \
ToCanonical + Simplify."
}], "Text",ExpressionUUID->"38ab4524-4dc8-490d-ab8f-315439d1c26f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definitions of manifolds, vector fields and actions", "Subsection",ExpressionUUID->"424f32b7-9d61-471a-9af3-96c597c2bfe4"],

Cell[CellGroupData[{

Cell["Manifolds and metrics", "Subsubsection",ExpressionUUID->"bb2d6604-6d3e-4601-8c64-c1579dcb9ab3"],

Cell[TextData[{
 "There is an internal type system in ",
 Cell[BoxData[
 "xAct`xTensor`"],ExpressionUUID->"1ad0cc67-0240-499a-a163-95a619829c8f"],
 " to specify geometric objects like ",
 Cell[BoxData[
 "Manifold"],ExpressionUUID->"86136b0a-eff0-4e73-a0cd-18259586af7c"],
 " and ",
 Cell[BoxData[
 "Metric"],ExpressionUUID->"1ca986e2-d916-4c62-b32d-13d5b1e45a61"],
 ". The functions to define/undefine types are named as:\n\t",
 Cell[BoxData[
  RowBox[{"\"\<Def/Undef\>\"", "<>", "\"\<type name\>\""}]],ExpressionUUID->
  "172b0f5c-c219-4579-ac41-7d1eee044b6e"],
 "\n\nThe manifold and metric are defined by ",
 Cell[BoxData[
 "DefManifold"],ExpressionUUID->"ffd89174-bf9d-45a6-bf59-ec880bfd8ded"],
 " and ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"455d7541-0513-4c5d-b79b-4705c4f04f22"],
 " respectively as follows,"
}], "Text",ExpressionUUID->"680c8e5f-fd18-4e89-8522-0910c633608b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DefManifold", "[", 
   RowBox[{"M", ",", "dim", ",", 
    RowBox[{"IndexRange", "[", 
     RowBox[{"a", ",", "z"}], "]"}]}], "]"}], ";"}]], "Code",
 CellLabel->"In[12]:=",ExpressionUUID->"076db241-d25f-4c88-afd9-bd1c70aa62ba"],

Cell[TextData[{
 "The arguments of ",
 Cell[BoxData[
 "DefManifold"],ExpressionUUID->"11365be8-edea-4395-95c8-b7603f9c4117"],
 " are the name, dimension and list of indices of the manifold. \nThe symbol ",
 Cell[BoxData["dim"],ExpressionUUID->"6c81513a-7b30-4704-8528-84ea03f7846d"],
 " represents any dimension in ",
 Cell[BoxData["xAct`"],ExpressionUUID->"f475ef6d-9b63-45c6-a0a2-80737e9ddf17"],
 ", printed as ",
 Cell[BoxData[
 "\"\<d\>\""],ExpressionUUID->"19e6183d-66f0-45cd-848e-ee7ae94de7b2"],
 ".\nIt\[CloseCurlyQuote]s convenient to use ",
 Cell[BoxData[
 "IndexRange"],ExpressionUUID->"12a5c6d2-223e-41a2-afc9-68a11b36249e"],
 " to assign indices."
}], "Text",ExpressionUUID->"0b9f057d-46ca-49e9-8aaa-f0454feba33e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DefMetric", "[", 
   RowBox[{
    RowBox[{"-", "1"}], ",", 
    RowBox[{"metric", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "CD", ",", 
    RowBox[{"SymbolOfCovD", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<;\>\"", ",", "\"\<\[Del]\>\""}], "}"}]}], ",", 
    RowBox[{"PrintAs", "->", "\"\<g\>\""}]}], "]"}], ";"}]], "Code",
 CellLabel->"In[13]:=",ExpressionUUID->"06fd1343-45f5-4f18-97c9-e5491ce76163"],

Cell[TextData[{
 "The arguments of ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"4b39f0c1-07e4-4731-b110-f61a6213e599"],
 " are the sign of determinant, the metric and the adapted Levi-Civita \
connection. \nThe option ",
 Cell[BoxData[
 "SymbolOfCovD"],ExpressionUUID->"89f9fe22-d828-4058-9afb-6d9807629474"],
 " specifies the postfix and prefix forms of the covariant derivative.\n\n",
 StyleBox["In ",
  FontWeight->"Bold"],
 Cell[BoxData["xAct`"],
  FontWeight->"Bold",ExpressionUUID->"9c197d07-1dfd-4b31-8b57-61854950a4cc"],
 StyleBox[" the lower indices are marked by minus sign.",
  FontWeight->"Bold"]
}], "Text",ExpressionUUID->"a6483658-48a5-4da7-95f5-1f4068c1706e"],

Cell[TextData[{
 Cell[BoxData[
 "PrintAs"],ExpressionUUID->"c3427d3d-d4c0-48ee-9201-cfd18e8f8ee4"],
 " is a common function and option telling ",
 Cell[BoxData["xAct`"],ExpressionUUID->"566036f2-f2de-48e3-9c57-931fe41fdb8c"],
 " how to print related symbols. \nIt's convenient to print the Levi-Civita \
symbol as ",
 Cell[BoxData[
 "\"\<\[Epsilon]\>\""],ExpressionUUID->"db30b970-617f-4b9c-a843-7ca0cead4dfd"],
 ", and the Riemann tensor, Ricci tensor and Ricci scalar all as ",
 Cell[BoxData[
 "\"\<R\>\""],ExpressionUUID->"d07676be-5bfb-46e1-842a-2275b4112f08"],
 "."
}], "Text",ExpressionUUID->"de007c75-a3b9-4568-b2ae-8dc11a1adc67"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RiemannCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RicciCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "RicciScalarCD", "]"}], "^=", "\"\<R\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"PrintAs", "[", "epsilonmetric", "]"}], "^=", 
   "\"\<\[Epsilon]\>\""}], ";"}]}], "Code",
 CellLabel->"In[14]:=",ExpressionUUID->"1743f7c9-433c-4995-977e-2582d4e1d5d4"],

Cell[TextData[{
 "The tangent bundle ",
 Cell[BoxData[
 "TangentM"],ExpressionUUID->"edb1c05a-f04c-4976-b5f3-746013ddda03"],
 " will be automatically defined after ",
 Cell[BoxData[
 "DefManifold"],ExpressionUUID->"a9825432-48d0-4349-845a-69bcdd9bf9ca"],
 ".\nSimilarly the metric determinant ",
 Cell[BoxData[
 "Detmetric"],ExpressionUUID->"9e6d1f05-21c9-4d15-a3e1-88dac943c735"],
 " and curvature-related tensors will be defined after ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"15d9868e-c0cc-4eb8-88ed-5f60a253cda3"],
 ". \n\nThe naming of these objects obeys the following form:\n\t",
 Cell[BoxData[
  RowBox[{"\"\<key word\>\"", "<>", "\"\<parent object name\>\""}]],
  ExpressionUUID->"d2828178-b19c-492d-b139-8b384d3371d6"]
}], "Text",ExpressionUUID->"48f1b77a-40e6-4da6-b099-0650b9e1a6da"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"TangentM", ",", 
   RowBox[{"Detmetric", "[", "]"}], ",", 
   RowBox[{"epsilonmetric", "[", 
