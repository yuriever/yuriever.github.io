Cell[TextData[{
 Cell[BoxData["CDT"],ExpressionUUID->"ef2173a9-a92a-4c5c-a743-3c4c77931487"],
 " is irrelevant to the following discussion and are undefined by"
}], "Text",ExpressionUUID->"7ac2e404-22a6-4193-bbab-b240a0d3edee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"UndefCovD", "@", "CDT"}]], "Input",
 CellLabel->"In[22]:=",ExpressionUUID->"9d544a3e-1165-4f80-b226-e581308de676"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"** \"\>", "\[InvisibleSpace]", "UndefCovD", 
