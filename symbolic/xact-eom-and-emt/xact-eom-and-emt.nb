4080e7d22a84"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "const", "]"}], ";"}], "\n", 
 RowBox[{"First", "@", 
  RowBox[{"SolveConstants", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"EMTTrace", "[", "conformalScalar", "]"}], "+", 
      RowBox[{"const", " ", 
       RowBox[{"EOM", "[", "conformalScalar", "]"}], 
       RowBox[{"phi", "[", "]"}]}]}], "==", "0"}], ",", "cs", ",", 
    RowBox[{"{", "const", "}"}]}], "]"}]}]}], "Code",
