   ",", "\<\"AIndexQ\"\>", ",", "\<\"BCIndexQ\"\>", ",", "\<\"BIndexQ\"\>", 
   ",", "\<\"CDIndexQ\"\>", ",", "\<\"CIndexQ\"\>", ",", "\<\"DIndexQ\"\>", 
   ",", "\<\"DownIndexQ\"\>", ",", "\<\"EIndexQ\"\>", ",", "\<\"GIndexQ\"\>", 
   ",", "\<\"LIndexQ\"\>", ",", "\<\"PIndexQ\"\>", ",", "\<\"UpIndexQ\"\>"}], 
  "}"}]], "Output",
 CellLabel->"Out[28]=",ExpressionUUID->"cd4c5c3e-dd74-481c-aab7-d5350c6c088e"]
}, Open  ]],

Cell[TextData[{
 "Built on ",
 Cell[BoxData[
 "IndexRule"],ExpressionUUID->"452f4f31-2d54-4117-b98f-b203b77cc2b8"],
 ", ",
 Cell[BoxData[
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{"LHS_", ",", "RHS_", ",", "conditions___"}], "}"}], "]"}]],
  ExpressionUUID->"de03bfa3-99cc-4796-8db4-6554c9579a37"],
 " provides more functionalities like checking index balance and taking \
account of tensor symmetry and metric contraction, which can be turned by \
options."
}], "Text",
 FontWeight->"Plain",ExpressionUUID->"eea76756-a86d-4f87-8c6f-995f2c43809c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MakeRule", "//", "Options"}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"d94e2c64-f956-4be1-9ca4-d06b206503ff"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"PatternIndices", "\[Rule]", "All"}], ",", 
   RowBox[{"TestIndices", "\[Rule]", "True"}], ",", 
   RowBox[{"MetricOn", "\[Rule]", "All"}], ",", 
   RowBox[{"UseSymmetries", "\[Rule]", "True"}], ",", 
   RowBox[{"Verbose", "\[Rule]", "False"}], ",", 
   RowBox[{"ContractMetrics", "\[Rule]", "True"}], ",", 
   RowBox[{"Evaluate", "\[Rule]", "False"}]}], "}"}]], "Output",
 CellLabel->"Out[29]=",ExpressionUUID->"78e77b4d-4be3-44a3-92a4-88fc6b6d9769"]
}, Open  ]],

Cell[TextData[{
 "Now the rule converting field strength to gauge potential can be defined as \
follows. Notice that there is no ",
 Cell[BoxData[
 "Pattern"],ExpressionUUID->"3964cb1e-1f03-4fb3-87d4-7e61777a46b7"],
 " in ",
 Cell[BoxData[
 "MakeRule"],ExpressionUUID->"c8f942cc-ac79-4cc4-842f-2ee9c54ada1e"],
 " comparing with ",
 Cell[BoxData[
 "RuleDelayed"],ExpressionUUID->"6d3858bd-b68e-4aab-97e7-8716e69c0fdd"],
 "."
}], "Text",ExpressionUUID->"d37079fb-56d4-49fa-b1fa-5586f45a0b20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ruleFToA", "=", 
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"F", "[", 
      RowBox[{"a", ",", "b"}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"CD", "[", "a", "]"}], "@", 
       RowBox[{"A", "[", "b", "]"}]}], "-", 
      RowBox[{
       RowBox[{"CD", "[", "b", "]"}], "@", 
       RowBox[{"A", "[", "a", "]"}]}]}]}], "}"}], "]"}]}]], "Code",
 CellLabel->"In[30]:=",ExpressionUUID->"953004f5-ebb0-4d11-ad46-417a437b3033"],

Cell[BoxData[
 RowBox[{"{", 
