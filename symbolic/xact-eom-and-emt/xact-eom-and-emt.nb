Cell[CellGroupData[{

Cell["User-defined vector fields", "Subsubsection",
 CellChangeTimes->{{3.8746357241064863`*^9, 
  3.874635737007299*^9}},ExpressionUUID->"7a0e1b12-722b-4d36-9c58-\
2ab1db4b6970"],

Cell[TextData[{
 "User-defined vector fields:\n\n",
 Cell[BoxData[
 "\[Phi]"],ExpressionUUID->"9edee7a0-b1fb-413b-b86d-6286b64217ba"],
 "\t\tscalar field\n",
 Cell[BoxData["A"],ExpressionUUID->"de2711fd-8301-46e1-86fe-4f26478b7eb9"],
 "\t\tU(1) gauge potential\n",
 Cell[BoxData["F"],ExpressionUUID->"62af137f-754d-49df-aa54-54fa2a8100cf"],
 "\t\tU(1) field strength\n",
 Cell[BoxData["cs"],ExpressionUUID->"56d4ab57-01e7-4a3c-9b45-e113ac924bdf"],
 "\t\tconstant\n",
 Cell[BoxData["alpha"],ExpressionUUID->"f4c7d27e-1582-4429-8f8b-c9273c67e22c"],
 "\tscalar function of ",
 Cell[BoxData["\[Phi]"],ExpressionUUID->"995cc708-b217-4dce-81d0-f8e9b54adf84"]
}], "Text",
 CellChangeTimes->{{3.874314121713806*^9, 3.874314131051128*^9}, {
  3.874318217149967*^9, 3.874318217406749*^9}, {3.874635933156583*^9, 
  3.87463608786124*^9}, {3.874636331559537*^9, 3.874636380102828*^9}, {
  3.874664404173562*^9, 3.87466445080226*^9}, {3.874720570497046*^9, 
  3.874720571462428*^9}, {3.875024558056594*^9, 3.875024594905451*^9}, {
  3.8750678429075947`*^9, 
  3.875067851126099*^9}},ExpressionUUID->"4ec77c61-e4d8-439d-aa8c-\
82f018b1768d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"phi", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Phi]\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], ",", "M"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "M", ",", 
    RowBox[{"Antisymmetric", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"cs", ",", 
    RowBox[{"PrintAs", "->", "\"\<c\>\""}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefScalarFunction", "[", 
   RowBox[{"alpha", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Alpha]\>\""}]}], "]"}], ";"}]}], "Code",
 CellChangeTimes->{{3.8605836567214136`*^9, 3.860583663333129*^9}, {
   3.860583786180087*^9, 3.8605837869832177`*^9}, {3.860583819074193*^9, 
   3.86058381924725*^9}, {3.8606126849646597`*^9, 3.860612758186241*^9}, {
   3.8606129002557545`*^9, 3.8606129093232894`*^9}, {3.8606134418759995`*^9, 
   3.860613442044799*^9}, {3.860613479662074*^9, 3.8606135095757723`*^9}, {
   3.86061354552407*^9, 3.8606135456921935`*^9}, {3.8611153393215027`*^9, 
