Cell[CellGroupData[{

Cell["Manifolds and metrics", "Subsubsection",
 CellChangeTimes->{{3.874291190639078*^9, 3.874291192288144*^9}, {
  3.874632169963982*^9, 3.8746321708300877`*^9}, {3.874635707465292*^9, 
  3.874635715206791*^9}},ExpressionUUID->"bb2d6604-6d3e-4601-8c64-\
c1579dcb9ab3"],

Cell[TextData[{
 "There is an internal type system in ",
 Cell[BoxData[
 "xAct`xTensor`"],ExpressionUUID->"1ad0cc67-0240-499a-a163-95a619829c8f"],
 " to specify geometric objects like ",
 Cell[BoxData[
 "Manifold"],ExpressionUUID->"86136b0a-eff0-4e73-a0cd-18259586af7c"],
 " and ",
 Cell[BoxData[
 "Metric"],ExpressionUUID->"1ca986e2-d916-4c62-b32d-13d5b1e45a61"],
 ". The functions to define/undefine types are named as:\n\t",
 Cell[BoxData[
  RowBox[{"\"\<Def/Undef\>\"", "<>", "\"\<type name\>\""}]],ExpressionUUID->
  "172b0f5c-c219-4579-ac41-7d1eee044b6e"],
 "\n\nThe manifold and metric are defined by ",
 Cell[BoxData[
 "DefManifold"],ExpressionUUID->"ffd89174-bf9d-45a6-bf59-ec880bfd8ded"],
 " and ",
 Cell[BoxData[
 "DefMetric"],ExpressionUUID->"455d7541-0513-4c5d-b79b-4705c4f04f22"],
 " respectively as follows,"
}], "Text",
 CellChangeTimes->{{3.874634768324757*^9, 3.8746347985078793`*^9}, 
   3.87463540179103*^9, {3.8746402091927843`*^9, 3.874640224524555*^9}, {
   3.874662395412539*^9, 3.874662425065414*^9}, {3.881632060224123*^9, 
   3.8816320840175467`*^9}, {3.881632140894897*^9, 3.881632154510414*^9}, {
   3.881632195840576*^9, 3.881632210694481*^9}, {3.88163246378646*^9, 
   3.881632540674325*^9}, {3.881632625804194*^9, 3.881632732804228*^9}, {
   3.8816328016231737`*^9, 3.881632826102193*^9}, {3.881646337576736*^9, 
   3.881646347609301*^9}},ExpressionUUID->"680c8e5f-fd18-4e89-8522-\
0910c633608b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DefManifold", "[", 
   RowBox[{"M", ",", "dim", ",", 
    RowBox[{"IndexRange", "[", 
     RowBox[{"a", ",", "z"}], "]"}]}], "]"}], ";"}]], "Code",
