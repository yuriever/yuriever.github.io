  3.875961777519195*^9}},ExpressionUUID->"0b27449c-ec2f-45ba-89d1-\
904be5b158b6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Off", "[", 
   RowBox[{"Solve", "::", "svars"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ansatzSolution", "[", "\"\<EOM\>\"", "]"}], "=", 
  RowBox[{"First", "@", 
   RowBox[{"SolveConstants", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ansatz", "[", "\"\<EOM\>\"", "]"}], "/.", "ruleFToA"}], ")"}],
      "==", 
     RowBox[{"EOM", "[", "abelianGauge", "]"}]}], "]"}]}]}]}], "Code",
 CellChangeTimes->{{3.875411536066312*^9, 3.875411545681777*^9}, {
  3.875411588171031*^9, 3.875411588644503*^9}, {3.875411678870617*^9, 
  3.875411683021598*^9}, {3.875909495562076*^9, 3.8759095608771257`*^9}},
