59c6f1f667a2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"EOM", "[", "field_", "]"}], "[", "action_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"measure", "@", "metric"}]}], " ", 
     RowBox[{
      RowBox[{"VarD", "[", 
       RowBox[{"field", ",", "CD"}], "]"}], "@", "action"}]}], "//", 
    "tensorSim"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"EMT", "[", "action_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"2", "/", 
      RowBox[{"measure", "@", "metric"}]}], " ", 
     RowBox[{
      RowBox[{"VarD", "[", 
       RowBox[{
        RowBox[{"metric", "[", 
         RowBox[{
          RowBox[{"-", "a"}], ",", 
          RowBox[{"-", "b"}]}], "]"}], ",", "CD"}], "]"}], "@", "action"}]}], 
    "//", "tensorSim"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"EMTTrace", "[", "action_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"EMT", "[", "action", "]"}], 
     RowBox[{"metric", "[", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "]"}]}], "//", "tensorSim"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.8750684119481487`*^9, 3.875068442571032*^9}, {
  3.87506848105542*^9, 3.8750685563109417`*^9}, {3.875386190610982*^9, 
