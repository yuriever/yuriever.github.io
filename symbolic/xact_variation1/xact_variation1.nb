Cell[TextData[{
 "When ",
 Cell[BoxData[
  RowBox[{"dim", "==", "4"}]],
  FormatType->StandardForm,ExpressionUUID->
  "87e62182-b550-481e-a1d2-c8c669193eb6"],
 " the trace ",
 Cell[BoxData[
  RowBox[{"traceEMT", "[", "A", "]"}]],
  FormatType->StandardForm,ExpressionUUID->
  "78ff2af4-0962-44b3-ac57-0e52455f0562"],
 " vanishes, implying that the action is invariant under Weyl transformation.\
\n\nThe trace ",
 Cell[BoxData[
  RowBox[{"traceEMT", "[", "phi", "]"}]],
  FormatType->StandardForm,ExpressionUUID->
  "bcba48a4-bf9b-4502-b114-3552e003e204"],
 " vanishes on-shell after choosing the constant ",
 Cell[BoxData["cs"],
  FormatType->StandardForm,ExpressionUUID->
  "0ebadd3c-4bbe-489f-8253-914cb568d0cb"],
 " correctly."
}], "Text",
 CellChangeTimes->{{3.874920703690859*^9, 3.874920764450818*^9}, {
  3.874920798496543*^9, 3.874920974196226*^9}, {3.8749210500323057`*^9, 
  3.874921052155098*^9}},ExpressionUUID->"8471c885-d064-4c34-9b1e-\
4b2a89971411"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "const", "]"}], "\n", 
 RowBox[{"SolveConstants", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"traceEMT", "[", "phi", "]"}], "+", 
     RowBox[{"const", " ", 
      RowBox[{"EOM", "[", "phi", "]"}], 
      RowBox[{"phi", "[", "]"}]}]}], "==", "0"}], ",", "cs", ",", 
   RowBox[{"{", "const", "}"}]}], "]"}]}], "Code",
 CellChangeTimes->{{3.874921071025041*^9, 3.8749211028034*^9}, {
  3.874921143957095*^9, 3.874921241131291*^9}, {3.874921315774971*^9, 
