Cell[BoxData[
 RowBox[{"ruleFToA", " ", "=", " ", 
  RowBox[{"MakeRule", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"F", "[", 
      RowBox[{"a", ",", "b"}], "]"}], ",", 
     RowBox[{
