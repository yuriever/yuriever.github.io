Cell[BoxData[{
 RowBox[{
  RowBox[{"EMT2", "[", "A", "]"}], "=", 
  RowBox[{"EMT", "[", 
   RowBox[{
    RowBox[{"action", "@", "A"}], "/.", "ruleFToA"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"EOM2", "[", "A", "]"}], "=", 
  RowBox[{
   RowBox[{"EOM", "[", 
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], "]"}], "[", 
   RowBox[{
    RowBox[{"action", "@", "A"}], "/.", "ruleFToA"}], "]"}]}]}], "Code",
 CellChangeTimes->{{3.874289069546884*^9, 3.874289076999218*^9}, {
  3.874289109713686*^9, 3.874289135001297*^9}, {3.8743361457263107`*^9, 
