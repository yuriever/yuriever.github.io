Cell["\<\
The following codes are already in lilyxact`.
The context specification like xAct`xTensor` is not necessary when working in \
notebook.\
\>", "Text",
 CellChangeTimes->{{3.868416633468545*^9, 3.868416654007821*^9}, {
  3.874313215813982*^9, 
  3.874313264220985*^9}},ExpressionUUID->"2214a0d9-ed86-4381-9a1d-\
3120f1b658b4"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}], " ", "=", " ", 
    RowBox[{"{", "\n", "    ", 
     RowBox[{
     "\"\<xAct`xPerm`\>\"", ",", "\n", "    ", "\"\<xAct`xTensor`\>\"", ",", 
      "\n", "    ", "\"\<xAct`xPert`\>\"", ",", "\n", "    ", 
      "\"\<xAct`Invar`\>\"", ",", "\n", "    ", "\"\<xAct`xCoba`\>\"", ",", 
      "\n", "    ", "\"\<xAct`SymManipulator`\>\"", ",", "\n", "    ", 
      "\"\<xAct`xTras`\>\"", ",", "\n", "    ", "\"\<xAct`TexAct`\>\""}], 
     "\n", "}"}]}], ";", "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"xAct`", " ", "is", " ", "not", " ", "re"}], "-", "Get", "-", 
      "able"}], ",", " ", 
     RowBox[{
     "and", " ", "there", " ", "are", " ", "conflict", " ", "symbols", " ", 
      "\n", "in", " ", "xAct`", " ", "and", " ", "GeneralUtilities`"}], ",", 
     " ", 
     RowBox[{
     "hence", " ", "Needs", " ", "is", " ", "better", " ", "than", " ", 
      RowBox[{"Get", "."}]}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "hide", " ", "the", " ", "version", " ", "messages", " ", "using", " ", 
     "Block", " ", "when", " ", "Needs"}], "*)"}], "\n", 
   RowBox[{"Block", "[", " ", 
    RowBox[{
     RowBox[{"{", "Print", "}"}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{"Needs", "/@", 
       RowBox[{"packageList", "[", "\"\<xAct\>\"", "]"}]}], ";"}]}], "\n", 
    "]"}], ";", "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "hide", " ", "the", " ", "dollar", " ", "symbols", " ", "of", " ", 
     "local", " ", "variables"}], "*)"}], "\n", 
   RowBox[{
   "System`$PrePrint", " ", "=", " ", "xAct`xTensor`ScreenDollarIndices"}], 
   ";", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "hide", " ", "the", " ", "definition", " ", "messages", " ", "of", " ", 
     "objects"}], "*)"}], "\n", 
   RowBox[{"xAct`xTensor`$DefInfoQ", " ", "=", " ", "False"}], ";", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "hide", " ", "the", " ", "verbose", " ", "messages", " ", "from", " ", 
     RowBox[{"ComponentValue", "."}]}], "*)"}], "\n", 
   RowBox[{"xAct`xCoba`$CVVerbose", " ", "=", " ", "False"}], ";", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "print", " ", "the", " ", "covariant", " ", "derivatives", " ", "as", " ",
      "prefix"}], "*)"}], "\n", 
   RowBox[{"xAct`xTensor`$CovDFormat", " ", "=", " ", "\"\<Prefix\>\""}], 
   ";"}], "*)"}]], "Code",
 CellChangeTimes->{{3.868133279992435*^9, 3.868133279996047*^9}, {
   3.86813332063454*^9, 3.868133321271337*^9}, {3.868133486272317*^9, 
   3.8681335677391443`*^9}, {3.8681422263813*^9, 3.8681422270350027`*^9}, {
   3.868149970353297*^9, 3.868149972432393*^9}, 3.868417294274118*^9, {
   3.868417416890373*^9, 3.868417423649791*^9}, {3.874278067602147*^9, 
   3.874278072214467*^9}, {3.874285221670969*^9, 3.874285278509529*^9}, {
   3.874285510464655*^9, 3.8742855195807323`*^9}, {3.874295905766618*^9, 
   3.874295909011573*^9}},ExpressionUUID->"58bb8e3a-2be1-4284-a134-\
6e7dc58ccbb9"],

Cell["\<\
The function measure is to give the sqrt of metric, and tensorSim is useful \
for simplification .\
\>", "Text",
 CellChangeTimes->{{3.874313294839818*^9, 
  3.874313315182908*^9}},ExpressionUUID->"cf8b5846-719d-4aff-8323-\
92a0c3a983ea"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"measure", "::", "usage"}], " ", "=", " ", 
       "\"\<Sqrt[-g]\>\""}], ";"}], "\n", 
     RowBox[{
      RowBox[{
       RowBox[{"tensorSim", "::", "usage"}], " ", "=", " ", 
       "\"\<x//ContractMetric//Simplification\>\""}], ";"}], "\n", "\n", 
     RowBox[{"measure", "[", 
      RowBox[{"metric_", "?", "xAct`xTensor`MetricQ"}], "]"}]}], " ", ":=", 
    "\n", "    ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"xAct`xTensor`SignDetOfMetric", "@", "metric"}], " ", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"\"\<Det\>\"", "<>", 
        RowBox[{"ToString", "@", "metric"}], "<>", "\"\<[]\>\""}], "]"}]}], 
     "]"}]}], ";", "\n", "\n", 
   RowBox[{
    RowBox[{"tensorSim", "[", "expr_", "]"}], " ", ":=", "\n", "    ", 
    RowBox[{
     RowBox[{"expr", "//", "xAct`xTensor`ContractMetric"}], "//", 
     "xAct`xTensor`Simplification"}]}], ";"}], "*)"}]], "Code",
 CellChangeTimes->{{3.868133279992435*^9, 3.868133279996047*^9}, {
   3.86813332063454*^9, 3.868133321271337*^9}, {3.868133486272317*^9, 
   3.8681335677391443`*^9}, {3.8681422263813*^9, 3.8681422270350027`*^9}, {
   3.868149970353297*^9, 3.868149972432393*^9}, 3.868417294274118*^9, {
   3.868417416890373*^9, 3.868417423649791*^9}, {3.874278067602147*^9, 
   3.874278072214467*^9}, {3.874285221670969*^9, 3.874285278509529*^9}, {
   3.874285510464655*^9, 3.874285518117844*^9}, {3.87429587919771*^9, 
   3.8742958978065357`*^9}},ExpressionUUID->"6a500efd-3cb5-4daf-b865-\
d87269470100"]
}, Open  ]],

