 "For convenience we have introduced the function ",
 Cell[BoxData["measure"],
  FormatType->StandardForm,ExpressionUUID->
  "8ff847ce-fc83-42a7-954e-a28a3735bba5"],
 " so that ",
 Cell[BoxData[
  RowBox[{"measure", "@", "metric"}]],
  FormatType->StandardForm,ExpressionUUID->
  "b45f12cc-4e70-4333-91d3-8f81d09acd0c"],
 " returns ",
 Cell[BoxData[
  RowBox[{"Sqrt", "[", 
   RowBox[{"-", 
    RowBox[{"Detmetric", "[", "]"}]}], "]"}]],
  FormatType->StandardForm,ExpressionUUID->
  "d1a4c1a3-40a5-4ce0-b1b0-2513314383bf"],
 ","
}], "Text",
