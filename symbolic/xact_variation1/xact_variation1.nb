   3.874285510464655*^9, 3.874285518117844*^9}, {3.87429587919771*^9, 
   3.8742958978065357`*^9}, 3.8743136166292152`*^9, {3.874660776744227*^9, 
   3.8746607824153547`*^9}},
 CellLabel->"In[34]:=",ExpressionUUID->"71970fbf-eecf-464f-9678-33d14a400cac"],

Cell[TextData[{
 "The function ",
 Cell[BoxData["measure"],
  FormatType->StandardForm,ExpressionUUID->
  "3f7a233b-6ed4-42b7-9760-4ebe836f0cbc"],
 " is to give the square root of metric determinant, and ",
 Cell[BoxData["tensorSim"],
  FormatType->StandardForm,ExpressionUUID->
  "43c0edcb-1d61-47e8-94aa-e82b5a1cef27"],
 " is useful for simplification."
}], "Text",
 CellChangeTimes->{{3.874664114933648*^9, 
  3.874664121526023*^9}},ExpressionUUID->"38ab4524-4dc8-490d-ab8f-\
315439d1c26f"]
}, Open  ]],

