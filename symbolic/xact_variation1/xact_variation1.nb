          Pattern[xAct`xTensor`Private`LHS, 
           Blank[]], 
          Pattern[xAct`xTensor`Private`RHS, 
           Blank[]], 
          Pattern[xAct`xTensor`Private`conditions, 
           BlankNullSequence[]]}, 
         Pattern[xAct`xTensor`Private`options, 
          OptionsPattern[]]] :> 
