Cell[TextData[{
 "The function ",
 Cell[BoxData["SolveConstants"],
  FormatType->StandardForm,ExpressionUUID->
  "caa27345-c1a8-420a-b56f-a6d3b8864c7d"],
 " built on ",
 Cell[BoxData["System`Solve"],
  FormatType->StandardForm,ExpressionUUID->
  "999f85dc-4bb6-4030-b08a-297e0bc07959"],
 " can solve coefficients in tensorial equations. \n\n",
 Cell[BoxData[
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"{", "eqs__", "}"}], ",", 
    RowBox[{"{", "vars__", "}"}], ",", 
    RowBox[{"{", "elims__", "}"}]}], "]"}]],
  FormatType->StandardForm,ExpressionUUID->
  "3f37b030-4ee9-4c11-a052-f3ac15c8a060"],
 " is an undocumented syntax, andsee \
https://mathematica.stackexchange.com/a/41263/86893."
}], "Text",
 CellChangeTimes->{{3.87492151865944*^9, 3.874921544818512*^9}, {
  3.874922588476388*^9, 3.874922674380125*^9}, {3.874922818393718*^9, 
  3.874922927975683*^9}, {3.874922959628026*^9, 
  3.8749230590973177`*^9}},ExpressionUUID->"59796a93-0087-4843-a6a7-\
1c7373109f7e"]
}, Open  ]],

