Cell[TextData[{
 "Sometimes it\[CloseCurlyQuote]s convenient to change the free indices of an \
expression according to another expression, ",
 StyleBox["FindFreeIndices",
  FontSlant->"Italic"],
 " and ",
 StyleBox["ChangeFreeIndices",
  FontSlant->"Italic"],
 " are designed for this purpose."
}], "Text",
 CellChangeTimes->{{3.874318329448703*^9, 
  3.8743184853858557`*^9}},ExpressionUUID->"604448d3-5669-494f-bd5c-\
3b59196ee188"],

Cell["Find the free indices in the stress tensor,", "Text",
 CellChangeTimes->{{3.874318515285638*^9, 3.874318610014546*^9}, {
  3.874318694632716*^9, 
  3.874318705907373*^9}},ExpressionUUID->"b3a592e8-c5b1-4f17-a00b-\
2ad275a003a3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FindFreeIndices", "@", 
  RowBox[{"Evaluate", "@", "EMT"}]}]], "Code",
 CellChangeTimes->{{3.8743185326174517`*^9, 3.8743185534293623`*^9}, 
   3.874318613668833*^9, {3.874318649104087*^9, 3.874318649264894*^9}, {
