           xAct`xTensor`Private`isolated = 
           xAct`xTensor`Private`ExtractIsolated[
            xAct`xTensor`Private`HeldLHS, Hold], 
           xAct`xTensor`Private`patindsLHS, xAct`xTensor`Private`ti, 
