Cell[TextData[{
 "This section is used to export SVG files and ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{"L", 
     StyleBox[
      AdjustmentBox["A",
       BoxBaselineShift->-0.4,
       BoxMargins->{{-0.5, -0.3}, {0, 0}}],
      FontSize->Smaller], "T", 
     AdjustmentBox["E",
      BoxBaselineShift->0.5,
      BoxMargins->{{-0.3, 0}, {0, 0}}], "X"}],
    SingleLetterItalics->False], TraditionalForm]],ExpressionUUID->
  "db3273a4-d680-407b-be33-c7733f513204"],
 " codes, and can be deleted."
}], "Text",
 CellChangeTimes->{{3.868142254274293*^9, 3.868142258050523*^9}, {
  3.868151631812306*^9, 3.86815170182928*^9}, {3.868151855560762*^9, 
  3.868151864024221*^9}, {3.8684179428523617`*^9, 3.8684179436870823`*^9}},
 Background->RGBColor[
  0.87, 0.94, 1],ExpressionUUID->"e1b8c381-435f-4e95-b606-c89c16db7c9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Needs", "[", "\"\<lily`xact`\>\"", "]"}], ";"}], "*)"}], "\n", 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"exportSVG", "[", "imgname_", "]"}], "[", "output_", "]"}], " ", 
    ":=", "\n", "    ", 
    RowBox[{"Module", "[", " ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"imgstring", ",", "imgpath"}], "}"}], ",", "\n", "        ", 
      RowBox[{
       RowBox[{"imgpath", " ", "=", " ", 
        RowBox[{
         RowBox[{"NotebookDirectory", "[", "]"}], "<>", "imgname", "<>", 
         "\"\<.svg\>\""}]}], ";", "\n", "        ", 
       RowBox[{"imgstring", " ", "=", " ", 
        RowBox[{"StringReplace", "[", "\n", "            ", 
         RowBox[{
          RowBox[{"ExportString", "[", 
           RowBox[{"output", ",", "\"\<SVG\>\""}], "]"}], ",", "\n", 
          "            ", 
          RowBox[{
           RowBox[{"\"\<width=\>\"", "~~", 
            RowBox[{"Shortest", "[", "__", "]"}], "~~", "\"\< viewBox\>\""}], 
           ":>", "\"\<viewBox\>\""}]}], "\n", "        ", "]"}]}], ";", "\n", 
       "        ", 
       RowBox[{"If", "[", " ", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"FileExistsQ", "@", "imgpath"}]}], ",", "\n", 
         "            ", 
         RowBox[{"CreateFile", "[", "imgpath", "]"}]}], "\n", "        ", 
        "]"}], ";", "\n", "        ", 
       RowBox[{"OpenWrite", "[", "imgpath", "]"}], ";", "\n", "        ", 
       RowBox[{"WriteString", "[", 
        RowBox[{"imgpath", ",", "imgstring"}], "]"}], ";", "\n", "        ", 
       RowBox[{"Close", "[", "imgpath", "]"}], ";", "\n", "        ", 
       "output"}]}], "\n", "    ", "]"}]}], ";"}]}]], "Code",
 CellChangeTimes->{{3.868416605148377*^9, 3.868416608179538*^9}, {
   3.8684172867015457`*^9, 3.868417293057207*^9}, 3.8684173844625607`*^9, {
