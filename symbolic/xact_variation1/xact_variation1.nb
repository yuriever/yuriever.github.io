Cell[TextData[{
 "The arguments of ",
 Cell[BoxData["DefMetric"],
  FormatType->StandardForm,ExpressionUUID->
  "4b39f0c1-07e4-4731-b110-f61a6213e599"],
 " are the sign of determinant, the metric and the adapted Levi-Civita \
connection. \nThe option ",
 Cell[BoxData["SymbolOfCovD"],
  FormatType->StandardForm,ExpressionUUID->
  "89f9fe22-d828-4058-9afb-6d9807629474"],
 " specifies the postfix and prefix forms of the covariant derivative."
}], "Text",
 CellChangeTimes->{{3.874664138245167*^9, 3.874664215169526*^9}, 
   3.874724760194075*^9},ExpressionUUID->"a6483658-48a5-4da7-95f5-\
1f4068c1706e"],

Cell[TextData[StyleBox["! Lower indices are marked by minus signs.",
 FontWeight->"Plain"]], "Text",
 CellChangeTimes->{
  3.874664210262879*^9},ExpressionUUID->"0c309665-69ad-464c-b6e0-\
bb0619c86a88"],

Cell[TextData[{
 Cell[BoxData["PrintAs"],
  FormatType->StandardForm,ExpressionUUID->
  "9b3f8d57-3c3e-4dae-9df2-61a3e234e2c6"],
 " is a common option telling ",
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,ExpressionUUID->
  "20e8512b-bda2-4bf8-b163-6e29e269494d"],
 " how to print related symbols. \nIt's convenient to print Riemann tensor, \
Ricci tensor and Ricci scalar as ",
 Cell[BoxData["R"],
  FormatType->StandardForm,ExpressionUUID->
  "4bfb110b-bde4-4148-ae9e-327e1902e83c"],
 "."
}], "Text",
 CellChangeTimes->{{3.874664138245167*^9, 
  3.874664215169526*^9}},ExpressionUUID->"de007c75-a3b9-4568-b2ae-\
8dc11a1adc67"],

Cell[TextData[{
 "The tangent bundle ",
 Cell[BoxData["TangentM"],
  FormatType->StandardForm,ExpressionUUID->
  "edb1c05a-f04c-4976-b5f3-746013ddda03"],
 " will be automatically defined after ",
 Cell[BoxData["DefManifold"],
  FormatType->StandardForm,ExpressionUUID->
  "a9825432-48d0-4349-845a-69bcdd9bf9ca"],
 ", and similarly the metric determinant ",
 Cell[BoxData["Detmetric"],
  FormatType->StandardForm,ExpressionUUID->
  "9e6d1f05-21c9-4d15-a3e1-88dac943c735"],
 " and curvature-related tensors will be defined after ",
 Cell[BoxData["DefMetric"],
  FormatType->StandardForm,ExpressionUUID->
  "15d9868e-c0cc-4eb8-88ed-5f60a253cda3"],
 ". \n\nFor example,"
}], "Text",
 CellChangeTimes->{{3.8746642281468687`*^9, 3.874664269491983*^9}, {
  3.874664362989695*^9, 3.874664364203846*^9}, {3.874720531168679*^9, 
  3.874720547524186*^9}, {3.8747207690256166`*^9, 
  3.874720772998616*^9}},ExpressionUUID->"48f1b77a-40e6-4da6-b099-\
0650b9e1a6da"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"TangentM", ",", 
   RowBox[{"Detmetric", "[", "]"}], ",", 
   RowBox[{"RiemannCD", "[", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "]"}]}], "}"}]], "Code",
 CellChangeTimes->{{3.874636141238605*^9, 3.8746361587762337`*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"46993e2f-a484-4863-8826-57913bd72d9f"],

