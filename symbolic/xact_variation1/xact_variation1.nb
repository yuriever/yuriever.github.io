Cell[TextData[{
 "The arguments of ",
 Cell[BoxData["DefManifold"],
  FormatType->StandardForm,ExpressionUUID->
  "11365be8-edea-4395-95c8-b7603f9c4117"],
 " are the name, dimension and list of indices of the manifold. \nThe symbol ",
 Cell[BoxData["dim"],
  FormatType->StandardForm,ExpressionUUID->
  "6c81513a-7b30-4704-8528-84ea03f7846d"],
 " represents any dimension in ",
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,ExpressionUUID->
  "f475ef6d-9b63-45c6-a0a2-80737e9ddf17"],
 ", printed as ",
 Cell[BoxData["d"],
  FormatType->StandardForm,ExpressionUUID->
  "60ff1f22-bc0d-45c3-8acd-723709776176"],
 ".\nIt\[CloseCurlyQuote]s convenient to use ",
 Cell[BoxData["IndexRange"],
  FormatType->StandardForm,ExpressionUUID->
  "12a5c6d2-223e-41a2-afc9-68a11b36249e"],
 " to assign indices."
}], "Text",
 CellChangeTimes->{{3.874664038258727*^9, 
  3.8746640590800657`*^9}},ExpressionUUID->"0b9f057d-46ca-49e9-8aaa-\
f0454feba33e"],

