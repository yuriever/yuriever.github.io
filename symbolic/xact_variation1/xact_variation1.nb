Cell["define the actions", "Text",
 CellChangeTimes->{{3.87428842347016*^9, 
  3.8742884356007853`*^9}},ExpressionUUID->"7e737bb0-8c6e-448f-a03b-\
17dab33660d3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"action", "[", "phi", "]"}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"measure", "[", "metric", "]"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}], 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "@", 
        RowBox[{"phi", "[", "]"}]}]}], "+", 
      RowBox[{"cs", " ", 
       RowBox[{"RicciScalarCD", "[", "]"}], " ", 
       RowBox[{
        RowBox[{"phi", "[", "]"}], "^", "2"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"action", "[", "A", "]"}], "=", 
   RowBox[{
    FractionBox["1", "4"], 
    RowBox[{"measure", "[", "metric", "]"}], 
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], 
    RowBox[{"F", "[", 
     RowBox[{"a", ",", "b"}], "]"}]}]}], ";"}]}], "Code",
 CellChangeTimes->{
  3.863807846054927*^9, {3.863808049597301*^9, 3.8638080511416063`*^9}, {
