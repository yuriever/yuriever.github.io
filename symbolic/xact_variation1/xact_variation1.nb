Cell[TextData[{
 "For ",
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,ExpressionUUID->
  "b1257005-72f2-47b8-90f8-bdced5484d66"],
 " packages ",
 Cell[BoxData["Needs"],
  FormatType->StandardForm,ExpressionUUID->
  "4d64961e-4325-446b-b511-d2925f8c9c9d"],
 " is better than ",
 Cell[BoxData["Get"],
  FormatType->StandardForm,ExpressionUUID->
  "add93fc4-874f-45ca-99c7-b1d9e60c79b8"],
 ". Besides there are conflict symbols in ",
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,ExpressionUUID->
  "aac9ba83-8d3e-4513-8d54-56acfba96e6c"],
 " and ",
 Cell[BoxData[
  RowBox[{"System`", "/", "GeneralUtilities`"}]],
  FormatType->StandardForm,ExpressionUUID->
  "89144ee2-fc3b-4679-88e8-f88bb10c52d8"],
 ".\nThe context specification like ",
 Cell[BoxData["xAct`xTensor`"],
  FormatType->StandardForm,ExpressionUUID->
  "0f861d3b-8347-4aab-b940-6590106c4450"],
 " is not necessary when working in notebook."
}], "Text",
 CellChangeTimes->{{3.874664091755135*^9, 3.8746641085437527`*^9}, {
  3.8747246521430798`*^9, 
  3.874724671443118*^9}},ExpressionUUID->"b3749d1d-d8d6-4fa8-a07c-\
dbf6a79cd6da"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"measure", "::", "usage"}], " ", "=", " ", "\"\<Sqrt[-g]\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"tensorSim", "::", "usage"}], " ", "=", " ", 
    "\"\<x//ContractMetric//Simplification\>\""}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"measure", "[", 
     RowBox[{"metric_", "?", "xAct`xTensor`MetricQ"}], "]"}], " ", ":=", "\n",
     "    ", 
    RowBox[{"Sqrt", "[", 
     RowBox[{
      RowBox[{"xAct`xTensor`SignDetOfMetric", "@", "metric"}], " ", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"\"\<Det\>\"", "<>", 
        RowBox[{"ToString", "@", "metric"}], "<>", "\"\<[]\>\""}], "]"}]}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"tensorSim", "[", "expr_", "]"}], " ", ":=", "\n", "    ", 
   RowBox[{
    RowBox[{"expr", "//", "xAct`xTensor`ContractMetric"}], "//", 
    "xAct`xTensor`Simplification"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.868133279992435*^9, 3.868133279996047*^9}, {
   3.86813332063454*^9, 3.868133321271337*^9}, {3.868133486272317*^9, 
   3.8681335677391443`*^9}, {3.8681422263813*^9, 3.8681422270350027`*^9}, {
