Cell["\<\
if not sure that EMT2[A] can be collected into A, make the redundant ansatz \
of CD^2 A^2 and then compare,\
\>", "Text",
 CellChangeTimes->{{3.874289334042508*^9, 3.874289402969345*^9}, {
  3.874289444448142*^9, 3.8742894547450857`*^9}, {3.874336327269823*^9, 
  3.8743363346567497`*^9}},ExpressionUUID->"e3e1b2e1-e20a-4c26-acf2-\
22b56933f331"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ansatz", "[", "\"\<EMT redundant\>\"", "]"}], "=", "\n", "\t", 
   RowBox[{
    RowBox[{"ansatz", "[", "\"\<EMT\>\"", "]"}], "+", "\n", "\t", 
    RowBox[{"MakeContractionAnsatz", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"A", "[", "b", "]"}]}], 
       RowBox[{
        RowBox[{"CD", "[", "c", "]"}], "@", 
        RowBox[{"A", "[", "d", "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}]}], "}"}], ",", 
      RowBox[{"ConstantPrefix", "->", "\"\<b\>\""}]}], "]"}]}]}], "\n", 
  "\t"}], "\n", 
 RowBox[{
  RowBox[{"SolveConstants", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ansatz", "[", "\"\<EMT redundant\>\"", "]"}], "/.", 
      "ruleFToA"}], ")"}], "==", 
    RowBox[{"EMT2", "[", "A", "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ansatz", "[", "\"\<EMT redundant\>\"", "]"}], "/.", 
  RowBox[{"First", "@", 
   RowBox[{"Out", "[", "]"}]}]}]}], "Code",
 CellChangeTimes->{{3.8480977472771673`*^9, 3.848097784211939*^9}, {
  3.848097829255274*^9, 3.8480978444017954`*^9}, {3.861115167133381*^9, 
  3.861115201106043*^9}, {3.868431232462359*^9, 3.868431239776822*^9}, {
