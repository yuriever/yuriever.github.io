Cell["\<\
if not sure that emtensor2[A] can be collected into A, make the redundant \
ansatz of CD^2 A^2 and then compare\
\>", "Text",
 CellChangeTimes->{{3.874289334042508*^9, 3.874289402969345*^9}, {
  3.874289444448142*^9, 
  3.8742894547450857`*^9}},ExpressionUUID->"e3e1b2e1-e20a-4c26-acf2-\
22b56933f331"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ansatz", "[", "\"\<emtensor redundant\>\"", "]"}], "=", "\n", 
   "\t", 
   RowBox[{
    RowBox[{"ansatz", "[", "\"\<emtensor\>\"", "]"}], "+", "\n", "\t", 
    RowBox[{"MakeContractionAnsatz", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"CD", "[", "a", "]"}], "@", 
        RowBox[{"A", "[", "b", "]"}]}], 
       RowBox[{
        RowBox[{"CD", "[", "c", "]"}], "@", 
        RowBox[{"A", "[", "d", "]"}]}]}], ",", 
      RowBox[{"{", 
