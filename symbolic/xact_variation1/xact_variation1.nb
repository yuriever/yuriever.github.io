       RowBox[{"A", "[", "b", "]"}]}], "-", 
      RowBox[{
       RowBox[{"CD", "[", "b", "]"}], "@", 
       RowBox[{"A", "[", "a", "]"}]}]}]}], "}"}], "]"}]}]], "Code",
