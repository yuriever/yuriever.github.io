  3.874720571462428*^9}},ExpressionUUID->"4ec77c61-e4d8-439d-aa8c-\
82f018b1768d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"phi", "[", "]"}], ",", "M", ",", 
    RowBox[{"PrintAs", "->", "\"\<\[Phi]\>\""}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"A", "[", 
     RowBox[{"-", "a"}], "]"}], ",", "M"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DefTensor", "[", 
   RowBox[{
    RowBox[{"F", "[", 
     RowBox[{
      RowBox[{"-", "a"}], ",", 
      RowBox[{"-", "b"}]}], "]"}], ",", "M", ",", 
    RowBox[{"Antisymmetric", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "a"}], ",", 
       RowBox[{"-", "b"}]}], "}"}], "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"DefConstantSymbol", "[", 
   RowBox[{"cs", ",", 
    RowBox[{"PrintAs", "->", "\"\<c\>\""}]}], "]"}], ";"}]}], "Code",
 CellChangeTimes->{{3.8605836567214136`*^9, 3.860583663333129*^9}, {
   3.860583786180087*^9, 3.8605837869832177`*^9}, {3.860583819074193*^9, 
   3.86058381924725*^9}, {3.8606126849646597`*^9, 3.860612758186241*^9}, {
   3.8606129002557545`*^9, 3.8606129093232894`*^9}, {3.8606134418759995`*^9, 
   3.860613442044799*^9}, {3.860613479662074*^9, 3.8606135095757723`*^9}, {
   3.86061354552407*^9, 3.8606135456921935`*^9}, {3.8611153393215027`*^9, 
   3.861115343924569*^9}, {3.861126706997135*^9, 3.861126707821253*^9}, {
   3.861126822935961*^9, 3.8611268397807207`*^9}, {3.8629001497438917`*^9, 
   3.862900150801654*^9}, {3.8637270794852*^9, 3.863727097084691*^9}, {
   3.874148078717531*^9, 3.874148082080945*^9}, {3.874148157676219*^9, 
   3.8741481650522957`*^9}, {3.8742900944842873`*^9, 3.874290094662088*^9}, {
   3.8743152216312923`*^9, 3.874315239394269*^9}, 3.8743354187378073`*^9, {
   3.874636384511845*^9, 3.874636386892128*^9}},
 CellLabel->"In[45]:=",ExpressionUUID->"74d6e2b4-a2f8-4ee4-b81d-2bb5b3a84815"],

Cell[TextData[{
 "The potential and field strength are related by\n\
$F_{ab}=\\partial_{[a}A_{b]}$\nand we need a method to impose this relation.\n\
\nIn Mathematica there are roughly two ways: ",
 Cell[BoxData[
  RowBox[{"Rule", "/", "RuleDelayed"}]],
  FormatType->StandardForm,ExpressionUUID->
  "76453915-6e3c-4a4e-ab1c-0b1687b45a63"],
 " vs. ",
 Cell[BoxData[
  RowBox[{"Set", "/", "SetDelayed"}]],
  FormatType->StandardForm,ExpressionUUID->
  "60fe31de-489d-4c60-965b-b6887bb2a909"],
 ", and ",
 Cell[BoxData["xAct`"],
  FormatType->StandardForm,ExpressionUUID->
  "bda5ec05-b8f8-4770-b44d-d21dc8f602d4"],
 " provides the function ",
 Cell[BoxData["MakeRule"],
  FormatType->StandardForm,ExpressionUUID->
  "15227445-3c4b-4ac0-b861-d86f7d59607b"],
 " (",
 Cell[BoxData["IndexSetDelayed"],
  FormatType->StandardForm,ExpressionUUID->
  "a5cc5879-9e8f-4849-bd31-b67d4c70fa69"],
 ") analogous to ",
 Cell[BoxData["Rule"],
  FormatType->StandardForm,ExpressionUUID->
  "a41d6e23-1647-4d9e-83ba-9148a1733669"],
 " (",
 Cell[BoxData["Set"],
  FormatType->StandardForm,ExpressionUUID->
  "977bba52-6d48-46a8-86fd-272e2b2cfa70"],
 ")."
}], "Text",
 CellChangeTimes->{{3.874664805486714*^9, 3.8746648055039177`*^9}, {
  3.874720578481722*^9, 3.8747206118011293`*^9}, {3.874722684260757*^9, 
  3.874722729770549*^9}, {3.874724859840152*^9, 
  3.874724865651198*^9}},ExpressionUUID->"382e7d32-e114-4d65-8f00-\
2fb548b471d4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"?", "MakeRule"}], "\n", 
 RowBox[{"?", "IndexSetDelayed"}]}], "Code",
 CellChangeTimes->{{3.874720831910899*^9, 3.874720837289916*^9}, {
  3.87472263572232*^9, 3.87472264192593*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"89b55a5a-5d2b-4540-a3b5-2fc37a861de6"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox["\<\" Symbol\"\>", "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"MakeRule[{LHS, RHS}] gives a list of delayed rules \
with left and right hand sides as given by LHS and RHS respectively, but \
moving indices to consider all possible equivalent rules. See notes for its \
options PatternIndices, MetricOn, UseSymmetries and TestIndices. \
MakeRule[{LHS, RHS, conditions}] adds conditions to the rules.\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"MakeRule", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`LHS_", ",", 
                    "xAct`xTensor`Private`RHS_", ",", 
                    "xAct`xTensor`Private`conditions___"}], "}"}], ",", 
                    RowBox[{"xAct`xTensor`Private`options", ":", 
                    RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
                    RowBox[{"With", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"xAct`xTensor`Private`HeldLHS", "=", 
                    RowBox[{"xAct`xTensor`Private`ReplaceIsolated", "[", 
                    RowBox[{"Hold", "[", "xAct`xTensor`Private`LHS", "]"}], 
                    "]"}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`HeldRHS", "=", 
                    RowBox[{"ReplaceDummies", "[", 
                    RowBox[{"Hold", "[", "xAct`xTensor`Private`RHS", "]"}], 
                    "]"}]}]}], "}"}], ",", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"xAct`xTensor`Private`indsLHS", "=", 
                    RowBox[{"List", "@@", 
                    RowBox[{"xAct`xTensor`Private`TakeEIndices", "[", 
                    
                    RowBox[{"FindIndices", "[", "xAct`xTensor`Private`LHS", 
                    "]"}], "]"}]}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`freesLHS", "=", 
                    RowBox[{"List", "@@", 
                    RowBox[{"xAct`xTensor`Private`TakeEIndices", "[", 
                    
                    RowBox[{"FindFreeIndices", "[", 
                    "xAct`xTensor`Private`LHS", "]"}], "]"}]}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`indsRHS", "=", 
                    RowBox[{"List", "@@", 
                    RowBox[{"xAct`xTensor`Private`TakeEIndices", "[", 
                    RowBox[{"FindIndices", "[", "xAct`xTensor`Private`RHS", 
                    "]"}], "]"}]}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`freesRHS", "=", 
                    RowBox[{"List", "@@", 
                    RowBox[{"xAct`xTensor`Private`TakeEIndices", "[", 
                    
                    RowBox[{"FindFreeIndices", "[", 
                    "xAct`xTensor`Private`RHS", "]"}], "]"}]}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`isolated", "=", 
                    RowBox[{"xAct`xTensor`Private`ExtractIsolated", "[", 
                    RowBox[{"xAct`xTensor`Private`HeldLHS", ",", "Hold"}], 
                    "]"}]}], ",", "xAct`xTensor`Private`patindsLHS", ",", 
                    "xAct`xTensor`Private`ti", ",", "xAct`xTensor`Private`mo",
                     ",", "xAct`xTensor`Private`us", ",", 
                    "xAct`xTensor`Private`verb", ",", 
                    "xAct`xTensor`Private`contr", ",", 
                    "xAct`xTensor`Private`ev", ",", 
                    "xAct`xTensor`Private`dupfreemetric", ",", 
                    "xAct`xTensor`Private`pmQinds", ",", 
                    "xAct`xTensor`Private`pairs", ",", 
                    "xAct`xTensor`Private`rulesLHS", ",", 
                    "xAct`xTensor`Private`symtensorsLHS", ",", 
                    "xAct`xTensor`Private`newLHSs", ",", 
                    "xAct`xTensor`Private`rules", ",", 
                    "xAct`xTensor`Private`conds"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`patindsLHS", ",", 
                    "xAct`xTensor`Private`ti", ",", "xAct`xTensor`Private`mo",
                     ",", "xAct`xTensor`Private`us", ",", 
                    "xAct`xTensor`Private`verb", ",", 
                    "xAct`xTensor`Private`contr", ",", 
                    "xAct`xTensor`Private`ev"}], "}"}], "=", 
                    RowBox[{"OptionValue", "[", 
                    RowBox[{"{", 
                    
                    RowBox[{"PatternIndices", ",", "TestIndices", ",", 
                    "MetricOn", ",", "UseSymmetries", ",", "Verbose", ",", 
                    "ContractMetrics", ",", "Evaluate"}], "}"}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"Or", "@@", 
                    
                    RowBox[{"PIndexQ", "/@", 
                    "xAct`xTensor`Private`indsLHS"}]}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"MakeRule", "::", "pats"}], "MessageName"], ",", 
                    "\"left\""}], "]"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"Or", "@@", 
                    
                    RowBox[{"PIndexQ", "/@", 
                    "xAct`xTensor`Private`indsRHS"}]}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"MakeRule", "::", "pats"}], "MessageName"], ",", 
                    "\"right\""}], "]"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"xAct`xTensor`Private`LHS", "===", "0"}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"MakeRule", "::", "error"}], "MessageName"], ",", 
                    "\"LHS of rule evaluates to zero.\""}], "]"}], "]"}]}], 
                    "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"Sort", "[", "xAct`xTensor`Private`freesLHS", 
                    "]"}], "=!=", 
                    
                    RowBox[{"Sort", "[", "xAct`xTensor`Private`freesRHS", 
                    "]"}]}], "&&", 
                    RowBox[{"xAct`xTensor`Private`RHS", "=!=", "0"}]}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    RowBox[{
                    StyleBox[
                    RowBox[{"MakeRule", "::", "inhom"}], "MessageName"], ",", 
                    "xAct`xTensor`Private`freesLHS", ",", 
                    "xAct`xTensor`Private`freesRHS"}], "]"}], "]"}]}], "]"}], 
                    ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", 
                    
                    RowBox[{"xAct`xTensor`Private`ListOfTerms", "[", 
                    "xAct`xTensor`Private`LHS", "]"}], "]"}], ">", "1"}], ",", 
                    RowBox[{"Throw", "[", 
                    RowBox[{"Message", "[", 
                    StyleBox[
                    RowBox[{"MakeRule", "::", "terms"}], "MessageName"], 
                    "]"}], "]"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"xAct`xTensor`Private`mo", "=!=", "None"}], "&&", 
                    
                    RowBox[{"xAct`xTensor`Private`careQ", "[", 
                    
                    RowBox[{"xAct`xTensor`Private`Identify", "[", 
                    "xAct`xTensor`Private`LHS", "]"}], "]"}]}], ",", 
                    
                    RowBox[{"Print", "[", 
                    "\"** MakeRule: Potential problems moving indices on the \
LHS.\"", "]"}]}], "]"}], ";", 
                    RowBox[{"With", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"xAct`xTensor`Private`LHSinfo", "=", 
                    RowBox[{"xAct`xTensor`Private`ConstructLHSinfo", "[", 
                    RowBox[{
                    
                    RowBox[{"xAct`xTensor`Private`IndexName", "/@", 
                    "xAct`xTensor`Private`indsLHS"}], ",", 
                    
                    RowBox[{"xAct`xTensor`Private`IndexName", "/@", 
                    "xAct`xTensor`Private`freesLHS"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`mo", ",", 
                    "xAct`xTensor`Private`ti", ",", 
                    "xAct`xTensor`Private`patindsLHS"}], "}"}]}], "]"}]}], 
                    "}"}], ",", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{"xAct`xTensor`Private`verb", ",", 
                    RowBox[{"Print", "[", 
                    
                    RowBox[{"\"LHSinfo: \"", ",", 
                    "xAct`xTensor`Private`LHSinfo"}], "]"}]}], "]"}], ";", 
                    RowBox[{"xAct`xTensor`Private`rulesLHS", "=", 
                    RowBox[{
                    
                    RowBox[{"xAct`xTensor`Private`FormatIndexRule", "/@", 
                    "xAct`xTensor`Private`LHSinfo"}], "/.", 
                    "\[VeryThinSpace]", 
                    RowBox[{"{", 
                    RowBox[{
                    
                    RowBox[{"xAct`xTensor`Private`patternTest", "\[Rule]", 
                    "PatternTest"}], ",", 
                    
                    RowBox[{"xAct`xTensor`Private`pattern", "\[Rule]", 
                    "Pattern"}]}], "}"}]}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{"xAct`xTensor`Private`verb", ",", 
                    RowBox[{"Print", "[", 
                    
                    RowBox[{"\"rulesLHS: \"", ",", 
                    "xAct`xTensor`Private`rulesLHS"}], "]"}]}], "]"}], ";", 
                    RowBox[{"xAct`xTensor`Private`pmQinds", "=", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"xAct`xTensor`Private`LHSinfo", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`index_", ",", "True", ",", 
                    "True", ",", "True", ",", "True", ",", "_"}], "}"}], 
                    "\[Rule]", "xAct`xTensor`Private`index"}]}], "]"}]}], ";", 
                    RowBox[{"xAct`xTensor`Private`pairs", "=", 
                    RowBox[{"Partition", "[", 
                    RowBox[{
                    RowBox[{"List", "@@", 
                    RowBox[{"xAct`xTensor`Private`TakeEPairs", "[", 
                    RowBox[{"IndexList", "@@", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"xAct`xTensor`Private`LHSinfo", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`index_", ",", "False", ",", 
                    "True", ",", "_", ",", "_", ",", "_"}], "}"}], "\[Rule]", 
                    "xAct`xTensor`Private`index"}]}], "]"}]}], "]"}]}], ",", 
                    "2"}], "]"}]}], ";", 
                    RowBox[{"xAct`xTensor`Private`dupfreemetric", "=", 
                    RowBox[{"Complement", "[", 
                    RowBox[{
                    RowBox[{"Cases", "[", 
                    RowBox[{"xAct`xTensor`Private`LHSinfo", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"xAct`xTensor`Private`index_", ",", "True", ",", 
                    "True", ",", "_", ",", "_", ",", "_"}], "}"}], "\[Rule]", 
                    "xAct`xTensor`Private`index"}]}], "]"}], ",", 
                    "xAct`xTensor`Private`pmQinds"}], "]"}]}], ";"}]}], "]"}],
                     ";", 
                    RowBox[{"xAct`xTensor`Private`symtensorsLHS", "=", 
                    RowBox[{"Cases", "[", 
                    RowBox[{
                    RowBox[{"Complement", "[", 
                    RowBox[{
                    RowBox[{"FindAllOfType", "[", 
                    RowBox[{"xAct`xTensor`Private`HeldLHS", ",", "Tensor"}], 
                    "]"}], ",", 
                    RowBox[{"FindAllOfType", "[", 
                    RowBox[{"xAct`xTensor`Private`isolated", ",", "Tensor"}], 
                    "]"}]}], "]"}], ",", 
                    RowBox[{"xAct`xTensor`Private`tensor_", "/;", 
                    RowBox[{
                    RowBox[{"OrderOfGroup", "[", 
                    
                    RowBox[{"SymmetryGroupOfTensor", "[", 
                    "xAct`xTensor`Private`tensor", "]"}], "]"}], "=!=", 
                    "1"}]}]}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{"xAct`xTensor`Private`verb", ",", 
                    RowBox[{"Print", "[", 
                    
                    RowBox[{"\"symtensorsLHS: \"", ",", 
                    "xAct`xTensor`Private`symtensorsLHS"}], "]"}]}], "]"}], 
                    ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"!", "xAct`xTensor`Private`us"}], "||", 
                    RowBox[{"xAct`xTensor`Private`symtensorsLHS", "===", 
                    RowBox[{"{", "}"}]}]}], ",", 
                    RowBox[{"xAct`xTensor`Private`newLHSs", "=", 
                    RowBox[{"{", "xAct`xTensor`Private`HeldLHS", "}"}]}], ",", 
                    RowBox[{"Module", "[", 
                    RowBox[{
