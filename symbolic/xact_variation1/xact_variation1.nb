Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"dim", " ", "is", " ", "the", " ", "pre"}], "-", 
     RowBox[{
     "defined", " ", "symbol", " ", "for", " ", "any", " ", "dimension", " ", 
      "in", " ", "xAct"}]}], ",", " ", 
    RowBox[{"printed", " ", "as", " ", "d"}]}], "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "use", " ", "IndexRange", " ", "to", " ", "assign", " ", "indices"}], 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"DefManifold", "[", 
     RowBox[{"M", ",", "dim", ",", 
      RowBox[{"IndexRange", "[", 
       RowBox[{"a", ",", "z"}], "]"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "the", " ", "first", " ", "argument", " ", "is", " ", "to", " ", 
     "specify", " ", "the", " ", "sign", " ", "of", " ", "the", " ", "metric",
      " ", "determinant"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "lower", " ", "indices", " ", "are", " ", "marked", " ", "by", " ", "the",
      " ", "minus", " ", "sign"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
      "the", " ", "third", " ", "argument", " ", "is", " ", "the", " ", 
       "Levi"}], "-", 
      RowBox[{"Civita", " ", "connection"}]}], ",", " ", 
     RowBox[{
     "which", " ", "will", " ", "be", " ", "defined", " ", "automatically", 
      " ", "after", " ", "DefMetric"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"DefMetric", "[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", 
      RowBox[{"metric", "[", 
       RowBox[{
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "b"}]}], "]"}], ",", "CD", ",", 
      RowBox[{"SymbolOfCovD", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<;\>\"", ",", "\"\<\[Del]\>\""}], "}"}]}], ",", 
      RowBox[{"PrintAs", "->", "\"\<g\>\""}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"print", " ", "Riemann", " ", "tensor"}], ",", " ", 
     RowBox[{
     "Ricci", " ", "tensor", " ", "and", " ", "Ricci", " ", "scalar", " ", 
      "as", " ", "R"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"PrintAs", "[", "RiemannCD", "]"}], "^=", "\"\<R\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PrintAs", "[", "RicciCD", "]"}], "^=", "\"\<R\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PrintAs", "[", "RicciScalarCD", "]"}], "^=", "\"\<R\>\""}], 
    ";"}]}]}]], "Code",
 CellChangeTimes->{{3.848055530650627*^9, 3.848055542213031*^9}, {
