Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "action", "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"action", "[", "phi", "]"}], "=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"measure", "@", "metric"}], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"CD", "[", "a", "]"}], "@", 
       RowBox[{"phi", "[", "]"}]}], 
      RowBox[{
       RowBox[{"CD", "[", 
        RowBox[{"-", "a"}], "]"}], "@", 
       RowBox[{"phi", "[", "]"}]}]}], "+", 
     RowBox[{"cs", " ", 
      RowBox[{"RicciScalarCD", "[", "]"}], " ", 
      RowBox[{
       RowBox[{"phi", "[", "]"}], "^", "2"}]}]}], 
    ")"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"action", "[", "A", "]"}], "=", 
  RowBox[{
   FractionBox["1", "4"], 
   RowBox[{"measure", "@", "metric"}], " ", 
   RowBox[{"F", "[", 
    RowBox[{
     RowBox[{"-", "a"}], ",", 
     RowBox[{"-", "b"}]}], "]"}], 
   RowBox[{"F", "[", 
    RowBox[{"a", ",", "b"}], "]"}]}]}]}], "Code",
 CellChangeTimes->{
