Cell[TextData[{
 "Here we choose ",
 Cell[BoxData["MakeRule"],
  FormatType->StandardForm,ExpressionUUID->
  "de03bfa3-99cc-4796-8db4-6554c9579a37"],
 " for finer control of the evaluation. Notice that there is no ",
 Cell[BoxData["Pattern"],
  FormatType->StandardForm,ExpressionUUID->
  "c11599d4-f159-4e87-b74a-14b77ce69e5e"],
 " in ",
 Cell[BoxData["MakeRule"],
  FormatType->StandardForm,ExpressionUUID->
  "d2757958-0ca3-47e6-8eaa-953140640918"],
 " comparing with ",
 Cell[BoxData["RuleDelayed"],
  FormatType->StandardForm,ExpressionUUID->
  "32caecda-8720-4193-8508-9714f71d88f2"],
 "."
}], "Text",
