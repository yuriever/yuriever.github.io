 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    StyleBox["\[DoubleStruckCapitalT]M",
     ShowAutoStyles->False,
     AutoSpacing->False],
    $CellContext`TangentM,
    Editable->False], ",", 
   InterpretationBox[
    StyleBox[
     OverscriptBox["g", 
      OverscriptBox[
       StyleBox["~",
        FontColor->RGBColor[0, 0, 0]], 
       StyleBox["~",
        FontColor->RGBColor[0, 0, 0]]]],
     ShowAutoStyles->False,
     AutoSpacing->False],
    $CellContext`Detmetric[],
    Editable->False], ",", 
   InterpretationBox[
    StyleBox[GridBox[{
       {"R", 
        StyleBox[GridBox[{
           {"a", "b", "c", "d"},
           {" ", " ", " ", " "}
          },
