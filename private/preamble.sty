% Number systems
% Reals
\newcommand{\R}{\mathbb{R}}
\newcommand{\Rnot}{\mathbb{R}^{\neq 0}}
\newcommand{\Rneq}{\mathbb{R}^{\neq 0}}
\newcommand{\Rgeq}{\mathbb{R}^{\geqslant 0}}
\newcommand{\Rpositive}{\mathbb{R}^{> 0}}
\newcommand{\Rleq}{\mathbb{R}^{\leqslant 0}}
\newcommand{\Rnegative}{\mathbb{R}^{< 0}}
% Integers
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Znot}{\mathbb{Z}^{\geqslant 0}}
\newcommand{\Zneq}{\mathbb{Z}^{\neq 0}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Zgeq}{\mathbb{Z}^{\geqslant 0}}
\newcommand{\Zpositive}{\mathbb{Z}^{> 0}}
\newcommand{\Zleq}{\mathbb{Z}^{\leqslant 0}}
\newcommand{\Znegative}{\mathbb{Z}^{< 0}}
% Rationals
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\Qnot}{\mathbb{Q}^{\geqslant 0}}
\newcommand{\Qneq}{\mathbb{Q}^{\neq 0}}
\newcommand{\Qgeq}{\mathbb{Q}^{\geqslant 0}}
\newcommand{\Qpositive}{\mathbb{Q}^{> 0}}
\newcommand{\Qleq}{\mathbb{Q}^{\leqslant 0}}
\newcommand{\Qnegative}{\mathbb{Q}^{< 0}}
% Complex numbers
\providecommand{\C}{\mathbb{C}}
\renewcommand{\C}{\mathbb{C}}
% \newmathcommand{\C}{\mathbb{C}}
\newcommand{\Cneq}{\mathbb{C}^{\neq 0}}
\newcommand{\Cnot}{\mathbb{C}^{\neq 0}}
% Projectives
\newmathcommand{\P}{\mathbb{P}}
% p-adic numbers
\newcommand{\Qp}{\mathbb{Q}_{p}}
\newcommand{\Zp}{\mathbb{Z}_{p\text{-adic}}}
\newcommand{\Up}{\mathbb{U}_{p}}


